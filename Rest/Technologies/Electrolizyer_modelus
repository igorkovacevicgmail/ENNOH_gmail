lots(figsize=(14, 7))\n","\n","    # 2. Primary axis: Compare Grid Import (Dispatch)\n","    ax1.set_xlabel('Time')\n","    ax1.set_ylabel('Power Dispatch (MW)', color='black')\n","\n","    # Define styles for potential cases\n","    styles = {\n","        \"Case_1\": {\"label\": \"Case 1: Linear\", \"color\": \"cyan\", \"style\": \":\"},\n","        \"Case_2\": {\"label\": \"Case 2: Min Load\", \"color\": \"orange\", \"style\": \"-\"},\n","        \"Case_3\": {\"label\": \"Case 3: Ramping\", \"color\": \"blue\", \"style\": \"-\"},\n","        \"Case_4\": {\"label\": \"Case 4: Efficiency Curve\", \"color\": \"purple\", \"style\": \"--\"},\n","        \"Case_5\": {\"label\": \"Case 5: Multi-Energy\", \"color\": \"green\", \"style\": \"-\"}\n","    }\n","\n","    # Plot available cases\n","    plotted_cases = []\n","    for case_key in sorted(summary.keys()):\n","        if case_key in styles:\n","            s = styles[case_key]\n","            ax1.step(summary[case_key].index, summary[case_key]['Grid Import (MW)'],\n","                     label=s[\"label\"], color=s[\"color\"], where='post', linewidth=2, linestyle=s[\"style\"], alpha=0.8)\n","            plotted_cases.append(case_key)\n","\n","    # Overlay Electricity Price (from the most recent case)\n","    last_case = list(summary.keys())[-1]\n","    ax1_price = ax1.twinx()\n","    ax1_price.step(summary[last_case].index, summary[last_case]['Electricity Price (€/MWh)'],\n","                   label='Electricity Price (€/MWh)', color='gray', linestyle=':', alpha=0.4, where='post')\n","    ax1_price.set_ylabel('Price (€/MWh)', color='gray')\n","\n","    # 3. Secondary axis: SoC\n","    ax2 = ax1.twinx()\n","    ax2.spines['right'].set_position(('outward', 60))\n","    ax2.set_ylabel('Storage SoC (MWh)', color='tab:red')\n","\n","    for case_key in sorted(summary.keys()):\n","        if case_key in styles:\n","            ax2.plot(summary[case_key].index, summary[case_key]['Hydrogen Tank SoC (MWh)'],\n","                     label=f\"{case_key} SoC\", linewidth=2, linestyle=':')\n","\n","    # 4. Final Formatting\n","    # Dynamic Title based on what is being compared\n","    if \"Case_1\" in plotted_cases and \"Case_3\" in plotted_cases:\n","        plt.title('Comparison: Case 1 (Linear) vs Case 3 (Ramping)')\n","    elif len(plotted_cases) == 2:\n","        plt.title(f'Comparison: {plotted_cases[0]} vs {plotted_cases[1]}')\n","    else:\n","        plt.title('Comparison of Electrolyzer Models')\n","\n","    fig.tight_layout()\n","\n","    # Legends\n","    lines1, labels1 = ax1.get_legend_handles_labels()\n","    lines2, labels2 = ax2.get_legend_handles_labels()\n","    ax1.legend(lines1 + lines2, labels1 + labels2, loc='upper left')\n","\n","    plt.grid(True, alpha=0.2)\n","    plt.show()"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x700 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]}]}