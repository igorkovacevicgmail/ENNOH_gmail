 bus explicitly so the generator can attach to it\n","network_El.add(\"Bus\", \"Electric bus\")\n","\n","# In your PyPSA code, apply this to the Grid Import generator:\n","network_El.add(\"Generator\", \"Grid Import\",\n","      bus=\"Electric bus\",\n","      p_nom=10,\n","      marginal_cost=german_prices_2025)\n","\n","# Verify the time-varying marginal cost was added correctly\n","print(\"Network snapshots:\", len(network_El.snapshots))\n","print(\"\\nMarginal Cost Profile (First 5 hours):\")\n","print(network_El.generators_t.marginal_cost.head())"],"metadata":{"id":"tX-FAQ2TEccD","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1773068884979,"user_tz":-60,"elapsed":118,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"b90cb98c-e415-479d-e6e8-a583b0dc909b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["WARNING:pypsa.network.io:The following buses are already defined and will be skipped (use overwrite=True to overwrite): Electric bus\n"]},{"output_type":"stream","name":"stdout","text":["Network snapshots: 24\n","\n","Marginal Cost Profile (First 5 hours):\n","name                 Grid Import\n","snapshot                        \n","2025-01-01 00:00:00         65.0\n","2025-01-01 01:00:00         62.0\n","2025-01-01 02:00:00         60.0\n","2025-01-01 03:00:00         62.0\n","2025-01-01 04:00:00         68.0\n"]}]},{"cell_type":"code","metadata":{"id":"2f8f8431","colab":{"base_uri":"https://localhost:8080/","height":377},"executionInfo":{"status":"ok","timestamp":1773069845431,"user_tz":-60,"elapsed":227,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"f46a9ea5-32b1-4071-a375-5d53d2ed9305"},"source":["import matplotlib.pyplot as plt\n","\n","# Extract the marginal cost for the Grid Import generator\n","marginal_costs = network_El.generators_t.marginal_cost[\"Grid Import\"]\n","\n","# Plotting\n","plt.figure(figsize=(10, 5))\n","plt.step(network_El.snapshots, marginal_costs, linestyle='-', where='post')\n","plt.title(\"Hourly Marginal Costs for Grid Import\")\n","plt.xlabel(\"Time\")\n","plt.ylabel(\"Marginal Cost (€/MWh)\")\n","plt.grid(True)\n","plt.xticks(rotation=45)\n","plt.tight_layout()\n","plt.show()"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["### Storage and Demand H2"],"metadata":{"id":"G61p_banLEsJ"}},{"cell_type":"code","source":["# Add a 'Store' component named \"Hydrogen Tank\"\n","# e_nom=100 means it can store 100 MWh of Hydrogen energy\n","network_El.add(\"Store\", \"Hydrogen Tank\",\n","            bus=\"Hydrogen bus\",\n","            e_nom=100)\n","\n","# 3. Create a list for the load profile\n","# The idea is define demand at the end of simulation period\n","target_load_profile = [0] * 23 + [50]\n","\n","# Add a new 'Load' component named \"Target Load\"\n","if \"Target Load\" in network_El.loads.index:\n","    network_El.remove(\"Load\", \"Target Load\")\n","\n","network_El.add(\"Load\", \"Target Load\",\n","            bus=\"Hydrogen bus\",\n","            p_set=target_load_profile)\n","\n","print(\"Added 'Hydrogen Tank' and 'Target Load' in the network.\")"],"metadata":{"id":"gv3qpRUAKE8V","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1773069858401,"user_tz":-60,"elapsed":46,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"8780a32e-5254-421a-eefe-7bf7553d3c72"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["WARNING:pypsa.network.io:The following stores are already defined and will be skipped (use overwrite=True to overwrite): Hydrogen Tank\n"]},{"output_type":"stream","name":"stdout","text":["Added 'Hydrogen Tank' and 'Target Load' in the network.\n"]}]},{"cell_type":"markdown","source":["### Electrolyzers Models"],"metadata":{"id":"HBeocKC7G3qU"}},{"cell_type":"markdown","source":["**The 5 Electrolyzer Models**\n","\n","**Layer 1**: The Basic Converter (Linear LP) \\\n","A simple, perfectly flexible \"black box\" that converts electricity to hydrogen at a flat efficiency (e.g., 70%). \\\n","Best for: High-level, long-term continental energy planning where you just need to estimate total megawatt capacity.\n","\n","**Layer 2**: The Part-Load Threshold (Basic MILP) \\\n","Introduces a minimum stable operating level (e.g., the plant must run at $\\geq 20\\%$ or be completely OFF). \\\n","Best for: Basic plant dispatch models where you want to prevent physically impossible \"micro-generation\" during moderately priced hours.\n","\n","**Layer 3**: Dynamic Inertia (Advanced MILP) \\\n","Adds the dimension of time. It enforces ramping limits (how fast the plant can power up/down) and applies financial/wear-and-tear penalties for cold starts.Best for: Grid stability studies and calculating realistic, sluggish reactions to rapid electricity price spikes.\n","\n","**Layer 4**: The True Efficiency Curve (Piecewise Linear) \\\n","Splits the electrolyzer into multiple parallel segments to capture the physics that electrolyzers actually run more efficiently at partial loads and less efficiently at peak loads.Best for: Maximizing precise hydrogen yield per MWh and calculating exact day-ahead operating profits.\n","\n","![efficiency.jpg](data:image/jpeg;base64,)\n","\n","**Layer 5**: Holistic Mass & Thermal Balance (4-Port MILP) \\\n","Connects four different physical buses simultaneously. It mathematically forces the plant to consume purified Water while outputting Hydrogen and capturing waste Heat.\n","\n","Best for: Detailed industrial plant design where water costs and district heating sales heavily influence the Levelized Cost of Hydrogen (LCOH).\n","\n"],"metadata":{"id":"cYemJZN7qjj7"}},{"cell_type":"code","source":["# Define which electrolyzer model to analyze\n","import numpy as np\n","import pandas as pd\n","\n","# Select the case (1-5)\n","case = 4\n","\n","# --- Clean up previous runs ---\n","# 1. Remove Links\n","links_to_remove = [\"Electrolyzer\"] + [l for l in network_El.links.index if \"Electrolyzer_L4_Segment\" in l]\n","for link in links_to_remove:\n","    if link in network_El.links.index:\n","        network_El.remove(\"Link\", link)\n","\n","# 2. Remove Case 5 Auxiliaries (to prevent duplicates or interference with other cases)\n","if \"Water Supply\" in network_El.generators.index:\n","    network_El.remove(\"Generator\", \"Water Supply\")\n","if \"District Heating\" in network_El.stores.index:\n","    network_El.remove(\"Store\", \"District Heating\")\n","\n","# --- Model Definitions ---\n","# Layer 1 - Simplest electrolyzer model (Linear)\n","if case == 1:\n","    network_El.add(\"Link\", \"Electrolyzer\",\n","        bus0=\"Electric bus\",\n","        bus1=\"Hydrogen bus\",\n","        p_nom=10,\n","        efficiency=0.70)\n","\n","# Layer 2 - Minimum part-load (Binary status)\n","if case == 2:\n","    network_El.add(\"Link\", \"Electrolyzer\",\n","        bus0=\"Electric bus\",\n","        bus1=\"Hydrogen bus\",\n","        p_nom=10,\n","        efficiency=0.70,\n","        committable=True,     # Enables binary On/Off variable\n","        p_min_pu=0.20)        # Min load 20% (2 MW)\n","\n","# Layer 3 - Dynamic constraints (Ramping, Start-up)\n","if case == 3:\n","    network_El.add(\"Link\", \"Electrolyzer\",\n","        bus0=\"Electric bus\",\n","        bus1=\"Hydrogen bus\",\n","        p_nom=10,\n","        efficiency=0.70,\n","        committable=True,\n","        ramp_limit_up=0.25,        # Max +25%/h\n","        ramp_limit_down=0.25,      # Max -25%/h\n","        ramp_limit_shut_down=0.25, # Ramp limits apply to shutdown too\n","        start_up_cost=500,\n","        min_up_time=4)\n","\n","# Layer 4 - True Efficiency Curve (Piecewise Linear)\n","if case == 4:\n","    # Define segments (Sum = 10 MW)\n","    power_segments = np.array([2.0, 2.0, 2.0, 2.0, 2.0])\n","\n","    # Efficiency curve (starts lower due to parasites, peaks at 40%, then drops due to ohmic losses)\n","    estimated_efficiencies = np.array([0.835, 0.840, 0.800, 0.740, 0.660])\n","\n","    # Enforce segment order (1->2->3->4->5) using marginal costs.\n","    marginal_cost_step = 2.0\n","\n","    for i in range(len(power_segments)):\n","        network_El.add(\"Link\", f\"Electrolyzer_L4_Segment_{i+1}\",\n","            bus0=\"Electric bus\",\n","            bus1=\"Hydrogen bus\",\n","            p_nom=power_segments[i],\n","            efficiency=estimated_efficiencies[i],\n","            marginal_cost=marginal_cost_step * (i + 1))\n","\n","# Layer 5 - Multi-energy balance (Power, H2, Water, Heat)\n","if case == 5:\n","    # 1. Add the Electrolyzer Link (4 ports)\n","    network_El.add(\"Link\", \"Electrolyzer\",\n","        bus0=\"Electric bus\",      # Power In\n","        bus1=\"Hydrogen bus\",      # H2 Out\n","        bus2=\"Water bus\",         # Water In\n","        bus3=\"Heat bus\",          # Heat Out\n","        p_nom=10,\n","        efficiency=0.70,          # Power -> H2\n","        efficiency2=-0.189,       # Power -> Water (Negative = Consumption)\n","        efficiency3=0.20,         # Power -> Heat (Positive = Production)\n","        committable=True,\n","        ramp_limit_up=0.25,\n","        ramp_limit_down=0.25,\n","        start_up_cost=500,\n","        min_up_time=4)\n","\n","    # 2. Add Water Supply (Required for balance)\n","    network_El.add(\"Generator\", \"Water Supply\",\n","        bus=\"Water bus\",\n","        p_nom=1000,\n","        marginal_cost=0.001) # Negligible cost\n","\n","    # 3. Add Heat Sink/Storage (Required for balance)\n","    network_El.add(\"Store\", \"District Heating\",\n","        bus=\"Heat bus\",\n","        e_nom=1000,\n","        e_initial=0)"],"metadata":{"id":"KOstdFHiZMJx"},"execution_count":null,"outputs":[]},{"cell_type":"