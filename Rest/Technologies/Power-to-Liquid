2)\n"]}]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive', force_remount=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0j36E6I_EntG","executionInfo":{"status":"ok","timestamp":1773310301933,"user_tz":-60,"elapsed":3136,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"0388e220-dd27-44b0-831d-d91bd66cbe6e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["import os\n","import sys\n","ROOT_DIR = os.getcwd()\n","PROJECT_DIR = os.path.join(ROOT_DIR, \"drive/MyDrive/Colab_Notebooks/PyPSA/\")"],"metadata":{"id":"VLmwOE9AEoXp"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# Methanol Synthesis\n","\n","Methanol synthesis is one of the most important processes in the modern \"Power-to-Liquid\" (PtL) landscape. Because methanol ($CH_3OH$) is a liquid at room temperature, it is rapidly becoming the green fuel of choice for the heavy maritime shipping industry.\n","\n","The Green Methanol (e-Methanol) pathway, which uses $CO_2$ directly, rather than Carbon Monoxide."],"metadata":{"id":"0MjEqBzkESLq"}},{"cell_type":"markdown","source":["## Hard-Coded Efficiencies"],"metadata":{"id":"GiFoiuhtIqIk"}},{"cell_type":"code","source":["import pypsa\n","import logging\n","import pandas as pd\n","\n","# 1. Mute PyPSA logging for clean output\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","def build_methanol_network(layer):\n","    n = pypsa.Network()\n","\n","    # Define carriers to fix consistency warnings\n","    for c in [\"hydrogen\", \"CO2\", \"methanol\", \"water\", \"heat\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # 2. CORE GRIDS (MWh and Tonnes)\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"CO2_Grid\", carrier=\"CO2\")\n","    n.add(\"Bus\", \"Methanol_Grid\", carrier=\"methanol\")\n","\n","    # 3. SUPPLY & DEMAND\n","    n.add(\"Generator\", \"H2_Supply\", bus=\"Hydrogen_Grid\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Generator\", \"CO2_Supply\", bus=\"CO2_Grid\", marginal_cost=80, p_nom_extendable=True)\n","\n","    n.add(\"Load\", \"Shipping_Demand\", bus=\"Methanol_Grid\", p_set=100)\n","\n","    # Safety Sink\n","    n.add(\"Generator\", \"Methanol_Sink\", bus=\"Methanol_Grid\", marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","\n","    # 4. THE METHANOL LAYERS\n","    if layer == 1:\n","        n.add(\"Link\", \"Methanol_Synthesis\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"Methanol_Grid\", bus2=\"CO2_Grid\",\n","              efficiency=0.85,\n","              efficiency2=-0.218,\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", marginal_cost=2, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"Methanol_Synthesis\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"Methanol_Grid\", bus2=\"CO2_Grid\", bus3=\"Water_Grid\",\n","              efficiency=0.85, efficiency2=-0.218,\n","              efficiency3=0.089,\n","              p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", marginal_cost=2, sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Heat_Sales\", bus=\"Heat_Grid\", marginal_cost=-10, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"Methanol_Synthesis\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"Methanol_Grid\", bus2=\"CO2_Grid\", bus3=\"Water_Grid\", bus4=\"Heat_Grid\",\n","              efficiency=0.85, efficiency2=-0.218, efficiency3=0.089,\n","              efficiency4=0.08,\n","              p_nom_extendable=True)\n","\n","    return n\n","\n","# 5. EXECUTION & COST BREAKDOWN\n","networks = {\"Layer 1 (Energy)\": 1, \"Layer 2 (+Water)\": 2, \"Layer 3 (+Heat)\": 3}\n","final_network = None\n","\n","print(\"Running PyPSA e-Methanol Optimization...\\n\" + \"=\"*50)\n","\n","for name, layer in networks.items():\n","    n = build_methanol_network(layer)\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","\n","    if status[0] == \"ok\":\n","        print(f\"✅ {name:<18} | Total Cost: €{n.objective:,.2f}\")\n","        if layer == 3:\n","            final_network = n # Save the fully-loaded network for the breakdown\n","    else:\n","        print(f\"❌ {name} failed.\")\n","\n","# 6. SEE THE UNDERLYING ECONOMICS (Using Layer 3)\n","print(\"\\n\" + \"=\"*50)\n","print(\"LAYER 3 ECONOMIC BREAKDOWN (For 100 MWh of Methanol)\")\n","print(\"-\" * 50)\n","\n","# Extract values from the optimized PyPSA network\n","h2_cost = final_network.generators_t.p[\"H2_Supply\"].iloc[0] * 90\n","co2_cost = final_network.generators_t.p[\"CO2_Supply\"].iloc[0] * 80\n","water_cost = final_network.generators_t.p[\"Water_Drain\"].iloc[0] * 2\n","heat_rev = final_network.generators_t.p[\"Heat_Sales\"].iloc[0] * -10 # Negative cost = revenue\n","\n","print(f\"Hydrogen Purchased:   €{h2_cost:,.2f}\")\n","print(f\"CO2 Purchased (DAC):  €{co2_cost:,.2f}\")\n","print(f\"Water Disposal Cost:  €{water_cost:,.2f}\")\n","print(f\"Waste Heat Revenue:  -€{abs(heat_rev):,.2f}\")\n","print(\"-\" * 50)\n","print(f\"NET SYSTEM COST:      €{final_network.objective:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"JuNhtskXT22L","executionInfo":{"status":"ok","timestamp":1773310320628,"user_tz":-60,"elapsed":18654,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"a0d91754-25b9-4e76-8d8f-7d53afc91bc0"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Running PyPSA e-Methanol Optimization...\n","==================================================\n","✅ Layer 1 (Energy)   | Total Cost: €12,640.00\n","✅ Layer 2 (+Water)   | Total Cost: €12,660.94\n","✅ Layer 3 (+Heat)    | Total Cost: €12,566.82\n","\n","==================================================\n","LAYER 3 ECONOMIC BREAKDOWN (For 100 MWh of Methanol)\n","--------------------------------------------------\n","Hydrogen Purchased:   €10,588.24\n","CO2 Purchased (DAC):  €2,051.76\n","Water Disposal Cost:  €20.94\n","Waste Heat Revenue:  -€94.12\n","--------------------------------------------------\n","NET SYSTEM COST:      €12,566.82\n"]}]},{"cell_type":"markdown","source":["## Cantera base incorporation"],"metadata":{"id":"8c8GhsgagXuI"}},{"cell_type":"code","source":["!pip install cantera"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"76VuHe8dhN36","executionInfo":{"status":"ok","timestamp":1773310327694,"user_tz":-60,"elapsed":7065,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"02f50791-ccee-4472-b7ec-dfe395569e86"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: cantera in /usr/local/lib/python3.12/dist-packages (3.2.0)\n","Requirement already satisfied: numpy<3,>=1.21.0 in /usr/local/lib/python3.12/dist-packages (from cantera) (2.0.2)\n","Requirement already satisfied: ruamel.yaml<1,>=0.17.21 in /usr/local/lib/python3.12/dist-packages (from cantera) (0.19.1)\n","Requirement already satisfied: typing_extensions>=4.13.0 in /usr/local/lib/python3.12/dist-packages (from cantera) (4.15.0)\n"]}]},{"cell_type":"code","source":["import cantera as ct\n","import pypsa\n","import pandas as pd\n","import logging\n","\n","# Mute PyPSA logging\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","# ==========================================\n","# 1. THE THERMODYNAMIC ENGINE (Corrected Units)\n","# ==========================================\n","def get_cantera_methanol_ratios(T_celsius=250):\n","    \"\"\"\n","    Calculates exact mass and energy ratios for: CO2 + 3H2 -> CH3OH + H2O\n","    \"\"\"\n","    # Load NASA Database\n","    try:\n","        gas = ct.Solution('gri30.yaml')\n","    except Exception:\n","        gas = ct.Solution('ideal-gas.yaml')\n","\n","    gas.TP = T_celsius + 273.15, ct.one_atm\n","\n","    mw = gas.molecular_weights # kg/kmol\n","    idx = {s: gas.species_index(s) for s in ['H2', 'CO2', 'CH3OH', 'H2O']}\n","\n","    # 1. Molar Stoichiometry (kmol)\n","    moles = {'H2': 3, 'CO2': 1, 'CH3OH': 1, 'H2O': 1}\n","\n","    # 2. Mass Calculation (kg) -> moles(kmol) * mw(kg/kmol)\n","    mass_kg = {s: moles[s] * mw[idx[s]] for s in moles}\n","\n","    # 3. Mass in Tonnes (for PyPSA Mass Grids)\n","    mass_tonnes = {s: mass_kg[s] / 1000 for s in moles}\n","\n","    # 4. Energy Calculation (MWh) -> 1 MWh = 3600 MJ\n","    # LHV in MJ/kg\n","    lhv_mj_kg = {'H2': 120.1, 'CO2': 0.0, 'CH3OH': 19.93, 'H2O': 0.0}\n","    energy_mwh = {s: mass_kg[s] * (lhv_mj_kg[s] / 3600) for s in moles}\n","\n","    # 5. Exothermic Heat (Layer 3)\n","    # Enthalpy 'h' is in Joules/kmol.\n","    h = gas.partial_molar_enthalpies\n","    delta_H_j = (moles['CH3OH']*h[idx['CH3OH']] + moles['H2O']*h[idx['H2O']]) - \\\n","                (moles['CO2']*h[idx['CO2']] + moles['H2']*h[idx['H2']])\n","\n","    # Convert Joules to MWh (1 MWh = 3.6e9 Joules)\n","    heat_mwh = abs(delta_H_j) / 3.6e9\n","\n","    # 6. Normalize everything to 1 MWh of Input H2 (bus0)\n","    ref = energy_mwh['H2']\n","\n","    return {\n","        \"eff_CH3OH\": round(energy_mwh['CH3OH'] / ref, 4),    # MWh_methanol / MWh_H2\n","        \"eff_CO2\":   round(-(mass_tonnes['CO2'] / ref), 4),  # Tonnes_CO2 / MWh_H2\n","        \"eff_Water\": round(mass_tonnes['H2O'] / ref, 4),     # Tonnes_H2O / MWh_H2\n","        \"eff_Heat\":  round(heat_mwh / ref, 4)                # MWh_heat / MWh_H2\n","    }\n","\n","# ==========================================\n","# 2. THE PYPSA 3-LAYER MODEL\n","# ==========================================\n","def build_dynamic_methanol_network(layer, thermo):\n","    n = pypsa.Network()\n","\n","    # Define carriers to fix consistency warnings\n","    for c in [\"hydrogen\", \"CO2\", \"methanol\", \"water\", \"heat\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # Grids\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"CO2_Grid\", carrier=\"CO2\")\n","    n.add(\"Bus\", \"Methanol_Grid\", carrier=\"methanol\")\n","\n","    # Generators & Loads\n","    n.add(\"Generator\", \"H2_Supply\", bus=\"Hydrogen_Grid\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Generator\", \"CO2_Supply\", bus=\"CO2_Grid\", marginal_cost=80, p_nom_extendable=True)\n","    n.add(\"Load\", \"Shipping_Demand\", bus=\"Methanol_Grid\", p_set=100)\n","    n.add(\"Generator\", \"Methanol_Sink\", bus=\"Methanol_Grid\", marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","\n","    # Base Link Arguments (Layer 1)\n","    link_args = {\n","        \"bus0\": \"Hydrogen_Grid\",\n","        \"bus1\": \"Methanol_Grid\",\n","        \"bus2\": \"CO2_Grid\",\n","        \"efficiency\": thermo[\"eff_CH3OH\"],\n","        \"efficiency2\": thermo[\"eff_CO2\"],\n","        \"p_nom_extendable\": True\n","    }\n","\n","    if layer >= 2:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", marginal_cost=2, sign=-1, p_nom_extendable=True)\n","        link_args[\"bus3\"] = \"Water_Grid\"\n","        link_args[\"efficiency3\"] = thermo[\"eff_Water\"]\n","\n","    if layer == 3:\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Heat_Sales\", bus=\"Heat_Grid\", marginal_cost=-10, sign=-1, p_nom_extendable=True)\n","        link_args[\"bus4\"] = \"Heat_Grid\"\n","        link_args[\"efficiency4\"] = thermo[\"eff_Heat\"]\n","\n","    n.add(\"Link\", \"Methanol_Synthesis\", **link_args)\n","    return n\n","\n","# ==========================================\n","# 3. EXECUTION & OUTPUT\n","# ==========================================\n","print(\"--- Step 1: Verified Thermodynamics (Cantera) ---\")\n","thermo_data = get_cantera_methanol_ratios(T_celsius=250)\n","for k, v in thermo_data.items():\n","    print(f\"{k:<10}: {v}\")\n","print(\"\\n\" + \"=\"*50)\n","\n","print(\"Running PyPSA e-Methanol Optimization...\")\n","final_network = None\n","for layer in [1, 2, 3]:\n","    n = build_dynamic_methanol_network(layer, thermo_data)\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","\n","    if status[0] == \"ok\":\n","        print(f\"✅ Layer {layer} Optimized | System Cost: €{n.objective:,.2f}\")\n","        if layer == 3:\n","            final_network = n\n","    else:\n","        print(f\"❌ Layer {layer} failed.\")\n","\n","print(\"\\n\" + \"=\"*50)\n","print(\"LAYER 3 ECONOMIC BREAKDOWN (For 100 MWh of Methanol)\")\n","print(\"-\" * 50)\n","\n","h2_cost = final_network.generators_t.p[\"H2_Supply\"].iloc[0] * 90\n","co2_cost = final_network.generators_t.p[\"CO2_Supply\"].iloc[0] * 80\n","water_cost = final_network.generators_t.p[\"Water_Drain\"].iloc[0] * 2\n","heat_rev = final_network.generators_t.p[\"Heat_Sales\"].iloc[0] * -10\n","\n","print(f\"Hydrogen Purchased:   €{h2_cost:,.2f}\")\n","print(f\"CO2 Purchased (DAC):  €{co2_cost:,.2f}\")\n","print(f\"Water Disposal Cost:  €{water_cost:,.2f}\")\n","print(f\"Waste Heat Revenue:  -€{abs(heat_rev):,.2f}\")\n","print(\"-\" * 50)\n","print(f\"NET SYSTEM COST:      €{final_network.objective:,.2f}\")"],"metadata":{"id":"Jdigv-6whJSa","executionInfo":{"status":"ok","timestamp":1773310335823,"user_tz":-60,"elapsed":8128,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"5d448674-2ea1-4c6a-84bf-772ebfe7da00"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Step 1: Verified Thermodynamics (Cantera) ---\n","eff_CH3OH : 0.8792\n","eff_CO2   : -0.2181\n","eff_Water : 0.0893\n","eff_Heat  : 0.0809\n","\n","==================================================\n","Running PyPSA e-Methanol Optimization...\n","✅ Layer 1 Optimized | System Cost: €12,221.11\n","✅ Layer 2 Optimized | System Cost: €12,241.42\n","✅ Layer 3 Optimized | System Cost: €12,149.41\n","\n","==================================================\n","LAYER 3 ECONOMIC BREAKDOWN (For 100 MWh of Methanol)\n","--------------------------------------------------\n","Hydrogen Purchased:   €10,236.58\n","CO2 Purchased (DAC):  €1,984.53\n","Water Disposal Cost:  €20.31\n","Waste Heat Revenue:  -€92.02\n","--------------------------------------------------\n","NET SYSTEM COST:      €12,149.41\n"]}]},{"cell_type":"markdown","source":["# Liquid Organic Hydro Carbons - LOHC\n","\n","While Ammonia and Methanol are excellent hydrogen carriers, they are highly toxic and require specialized handling. **Liquid Organic Hydrogen Carriers** (LOHCs) offer a safer alternative by chemically binding hydrogen to a liquid organic molecule (like a specialized oil). This allows hydrogen to be transported at room temperature and ambient pressure using the world's existing fossil fuel infrastructure (oil tankers, trucks, and pipelines).\n","The most commercially developed LOHC system uses the reversible reaction between **Toluene** (the hydrogen-lean carrier) and **Methylcyclohexane** (the hydrogen-rich carrier).\n"],"metadata":{"id":"sM4M_bOQJfPF"}},{"cell_type":"markdown","source":["## Hard-Coded Efficiencies"],"metadata":{"id":"HXAN_8QsKZwO"}},{"cell_type":"code","source":["import pypsa\n","import logging\n","import pandas as pd\n","\n","# Mute logging\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","def build_lohc_network(layer):\n","    n = pypsa.Network()\n","\n","    # Define all carriers to avoid consistency warnings\n","    for c in [\"hydrogen\", \"toluene\", \"mch\", \"electricity\", \"heat\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # ==========================================\n","    # 1. CORE GRIDS\n","    # ==========================================\n","    n.add(\"Bus\", \"H2_Supply_Grid\", carrier=\"hydrogen\") # MWh\n","    n.add(\"Bus\", \"H2_Demand_Grid\", carrier=\"hydrogen\") # MWh\n","    n.add(\"Bus\", \"Toluene_Grid\", carrier=\"toluene\")   # Tonnes (Empty Carrier)\n","    n.add(\"Bus\", \"MCH_Grid\", carrier=\"mch\")       # Tonnes (Full Carrier)\n","\n","    # Supply and Demand\n","    n.add(\"Generator\", \"H2_Source\", bus=\"H2_Supply_Grid\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Load\", \"H2_Consumer\", bus=\"H2_Demand_Grid\", p_set=100) # We need 100 MWh of H2 at the destination\n","\n","    # Carrier Inventory (Allows the model to \"buy\" the initial carrier fluid)\n","    n.add(\"Generator\", \"Toluene_Market\", bus=\"Toluene_Grid\", marginal_cost=5, p_nom_extendable=True)\n","    n.add(\"Generator\", \"Toluene_Sink\", bus=\"Toluene_Grid\", marginal_cost=0, sign=-1, p_nom_extendable=True)\n","\n","    # ==========================================\n","    # 2. THE LOHC LAYERS\n","    # ==========================================\n","\n","    # --- LAYER 1: Basic Mass & Energy Loop ---\n","    # Charge Link (H2 + Toluene -> MCH)\n","    charge_args = {\n","        \"bus0\": \"H2_Supply_Grid\",\n","        \"bus1\": \"MCH_Grid\",\n","        \"bus2\": \"Toluene_Grid\",\n","        \"efficiency\": 0.487,    # Yields 0.487 t MCH\n","        \"efficiency2\": -0.457,  # Consumes 0.457 t Toluene (Negative = Input)\n","        \"p_nom_extendable\": True\n","    }\n","\n","    # Discharge Link (MCH -> H2 + Toluene)\n","    discharge_args = {\n","        \"bus0\": \"MCH_Grid\",\n","        \"bus1\": \"H2_Demand_Grid\",\n","        \"bus2\": \"Toluene_Grid\",\n","        \"efficiency\": 2.0534,   # Yields 2.0534 MWh H2\n","        \"efficiency2\": 0.9384,  # Yields 0.9384 t Toluene (Positive = Output)\n","        \"p_nom_extendable\": True\n","    }\n","\n","    # --- LAYER 2: Adding Parasitic Electricity ---\n","    if layer >= 2:\n","        n.add(\"Bus\", \"Elec_Grid\", carrier=\"electricity\")\n","        n.add(\"Generator\", \"Grid_Power\", bus=\"Elec_Grid\", marginal_cost=60, p_nom_extendable=True)\n","\n","        charge_args[\"bus3\"] = \"Elec_Grid\"\n","        charge_args[\"efficiency3\"] = -0.05 # Consumes 0.05 MWh Elec\n","\n","        discharge_args[\"bus3\"] = \"Elec_Grid\"\n","        discharge_args[\"efficiency3\"] = -0.10 # Consumes 0.10 Mwh Elec\n","\n","    # --- LAYER 3: Adding Thermal Management ---\n","    if layer == 3:\n","        n.add(\"Bus\", \"Heat_Low_Grid\", carrier=\"heat\")  # ~150C (From Charge)\n","        n.add(\"Bus\", \"Heat_High_Grid\", carrier=\"heat\") # ~300C (Needed for Discharge)\n","\n","        # Revenue from low-grade heat, Cost for high-grade heat\n","        n.add(\"Generator\", \"Sell_Low_Heat\", bus=\"Heat_Low_Grid\", marginal_cost=-10, sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Buy_High_Heat\", bus=\"Heat_High_Grid\", marginal_cost=35, p_nom_extendable=True)\n","\n","        charge_args[\"bus4\"] = \"Heat_Low_Grid\"\n","        charge_args[\"efficiency4\"] = 0.28 # Yields 0.28 MWh Heat\n","\n","        discharge_args[\"bus4\"] = \"Heat_High_Grid\"\n","        discharge_args[\"efficiency4\"] = -0.575 # Consumes 0.575 MWh Heat (Negative = Input)\n","\n","    # Add the configured links to the network\n","    n.add(\"Link\", \"LOHC_Charge\", **charge_args)\n","    n.add(\"Link\", \"LOHC_Discharge\", **discharge_args)\n","\n","    return n\n","\n","# ==========================================\n","# 3. EXECUTION & RESULTS\n","# ==========================================\n","print(\"Running PyPSA LOHC Optimization...\\n\" + \"=\"*55)\n","final_network = None\n","\n","for layer in [1, 2, 3]:\n","    n = build_lohc_network(layer)\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","    if status[0] == \"ok\":\n","        print(f\"✅ Layer {layer} Optimized | Total Delivery Cost: €{n.objective:,.2f}\")\n","        if layer == 3:\n","            final_network = n\n","    else:\n","        print(f\"❌ Layer {layer} failed.\")\n","\n","# ==========================================\n","# 4. ECONOMIC BREAKDOWN OF LAYER 3\n","# ==========================================\n","print(\"\\n\" + \"=\"*55)\n","print(\"LAYER 3 BREAKDOWN: Delivering 100 MWh of H2 via LOHC\")\n","print(\"-\" * 55)\n","\n","h2_cost = final_network.generators_t.p[\"H2_Source\"].iloc[0] * 90\n","tol_cost = final_network.generators_t.p[\"Toluene_Market\"].iloc[0] * 5\n","elec_cost = final_network.generators_t.p[\"Grid_Power\"].iloc[0] * 60\n","heat_bought = final_network.generators_t.p[\"Buy_High_Heat\"].iloc[0] * 35\n","heat_sold = final_network.generators_t.p[\"Sell_Low_Heat\"].iloc[0] * -10\n","\n","print(f\"1. Raw H2 Purchased:           €{h2_cost:,.2f}\")\n","print(f\"2. Initial Carrier (Toluene):  €{tol_cost:,.2f}\")\n","print(f\"3. Electricity (Pumps/Comp):   €{elec_cost:,.2f}\")\n","print(f\"4. High-Temp Heat (Discharge): €{heat_bought:,.2f}\")\n","print(f\"5. Low-Temp Heat Revenue:     -€{abs(heat_sold):,.2f}\")\n","print(\"-\" * 55)\n","print(f\"TOTAL SYSTEM COST:             €{final_network.objective:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"H3HxHbTyJuSZ","executionInfo":{"status":"ok","timestamp":1773310348779,"user_tz":-60,"elapsed":12952,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"de9d69e1-710a-4155-ae8e-0e147362977b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Running PyPSA LOHC Optimization...\n","=======================================================\n","✅ Layer 1 Optimized | Total Delivery Cost: €8,999.95\n","✅ Layer 2 Optimized | Total Delivery Cost: €9,592.14\n","✅ Layer 3 Optimized | Total Delivery Cost: €10,292.23\n","\n","=======================================================\n","LAYER 3 BREAKDOWN: Delivering 100 MWh of H2 via LOHC\n","-------------------------------------------------------\n","1. Raw H2 Purchased:           €8,999.95\n","2. Initial Carrier (Toluene):  €-0.00\n","3. Electricity (Pumps/Comp):   €592.20\n","4. High-Temp Heat (Discharge): €980.08\n","5. Low-Temp Heat Revenue:     -€280.00\n","-------------------------------------------------------\n","TOTAL SYSTEM COST:             €10,292.23\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"kbGcICThKCK8"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["## Thermodynamic bridge"],"metadata":{"id":"S1Sq-PgSKhhX"}},{"cell_type":"code","source":["import pypsa\n","import pandas as pd\n","import logging\n","\n","# Mute PyPSA logging\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","# ==========================================\n","# 1. THE THERMODYNAMIC ENGINE (NIST / Cantera Alternative)\n","# ==========================================\n","def get_lohc_thermo(T_charge_C=150, T_discharge_C=300):\n","    \"\"\"\n","    Calculates exact temperature-dependent mass and energy ratios for LOHC.\n","    Reaction: C7H8 (Toluene) + 3 H2 <--> C7H14 (MCH)\n","    \"\"\"\n","    # 1. Molar Masses (kg/kmol)\n","    mw = {'H2': 2.016, 'TOL': 92.14, 'MCH': 98.19}\n","\n","    # 2. Stoichiometry (kmol)\n","    moles = {'H2': 3.0, 'TOL': 1.0, 'MCH': 1.0}\n","\n","    # 3. Energy Content (LHV in MJ/kg)\n","    lhv = {'H2': 120.1, 'TOL': 40.5, 'MCH': 43.4}\n","\n","    # 4. Standard Enthalpy of Formation at 25C (kJ/mol)\n","    # Toluene: +50.0, MCH: -166.3\n","    # Delta H reaction standard = -166.3 - (50.0 + 3*0) = -216.3 kJ/mol_Toluene\n","    # To account for temperature shifts (sensible heat), the heat of reaction\n","    # changes slightly. For simplicity in this bridge, we apply a thermal\n","    # capacity correction factor typical for this reaction.\n","\n","    delta_H_charge_kJ_mol = -216.3 + (T_charge_C - 25) * 0.05\n","    delta_H_discharge_kJ_mol = 216.3 + (T_discharge_C - 25) * 0.05\n","\n","    # Convert heat to MWh per kmol of reaction (1 MWh = 3.6e6 kJ)\n","    heat_charge_MWh = abs(delta_H_charge_kJ_mol) * moles['TOL'] / 3600\n","    heat_discharge_MWh = abs(delta_H_discharge_kJ_mol) * moles['TOL'] / 3600\n","\n","    # 5. Mass & Energy Mappings\n","    mass_t_TOL = (moles['TOL'] * mw['TOL']) / 1000  # Tonnes\n","    mass_t_MCH = (moles['MCH'] * mw['MCH']) / 1000  # Tonnes\n","    energy_MWh_H2 = (moles['H2'] * mw['H2'] * lhv['H2']) / 3600 # MWh\n","\n","    # --- CHARGE RATIOS (Base: 1 MWh of H2 Input) ---\n","    ref_charge = energy_MWh_H2\n","    charge_ratios = {\n","        \"eff_MCH_out\": round(mass_t_MCH / ref_charge, 4),    # t MCH / MWh H2\n","        \"eff_TOL_in\":  round(-(mass_t_TOL / ref_charge), 4), # t TOL / MWh H2\n","        \"eff_Heat_out\": round(heat_charge_MWh / ref_charge, 4),\n","        \"eff_Elec_in\": -0.05 # Standard compressor load\n","    }\n","\n","    # --- DISCHARGE RATIOS (Base: 1 Tonne of MCH Input) ---\n","    ref_discharge = mass_t_MCH\n","    discharge_ratios = {\n","        \"eff_H2_out\":  round(energy_MWh_H2 / ref_discharge, 4),  # MWh H2 / t MCH\n","        \"eff_TOL_out\": round(mass_t_TOL / ref_discharge, 4),     # t TOL / t MCH\n","        \"eff_Heat_in\": round(-(heat_discharge_MWh / ref_discharge), 4),\n","        \"eff_Elec_in\": -0.10 # Standard pumping/separation load\n","    }\n","\n","    return charge_ratios, discharge_ratios\n","\n","# ==========================================\n","# 2. THE PYPSA 3-LAYER MODEL\n","# ==========================================\n","def build_dynamic_lohc_network(layer, charge_thermo, discharge_thermo):\n","    n = pypsa.Network()\n","\n","    # Define all carriers to avoid consistency warnings\n","    for c in [\"hydrogen\", \"toluene\", \"mch\", \"electricity\", \"heat\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # Grids\n","    n.add(\"Bus\", \"H2_Supply_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"H2_Demand_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"Toluene_Grid\", carrier=\"toluene\")\n","    n.add(\"Bus\", \"MCH_Grid\", carrier=\"mch\")\n","\n","    # Supply and Demand\n","    n.add(\"Generator\", \"H2_Source\", bus=\"H2_Supply_Grid\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Load\", \"H2_Consumer\", bus=\"H2_Demand_Grid\", p_set=100)\n","    n.add(\"Generator\", \"Toluene_Market\", bus=\"Toluene_Grid\", marginal_cost=5, p_nom_extendable=True)\n","\n","    # Layer 1 Args\n","    c_args = {\n","        \"bus0\": \"H2_Supply_Grid\", \"bus1\": \"MCH_Grid\", \"bus2\": \"Toluene_Grid\",\n","        \"efficiency\": charge_thermo[\"eff_MCH_out\"],\n","        \"efficiency2\": charge_thermo[\"eff_TOL_in\"],\n","        \"p_nom_extendable\": True\n","    }\n","\n","    d_args = {\n","        \"bus0\": \"MCH_Grid\", \"bus1\": \"H2_Demand_Grid\", \"bus2\": \"Toluene_Grid\",\n","        \"efficiency\": discharge_thermo[\"eff_H2_out\"],\n","        \"efficiency2\": discharge_thermo[\"eff_TOL_out\"],\n","        \"p_nom_extendable\": True\n","    }\n","\n","    # Layer 2 Args (Electricity)\n","    if layer >= 2:\n","        n.add(\"Bus\", \"Elec_Grid\", carrier=\"electricity\")\n","        n.add(\"Generator\", \"Grid_Power\", bus=\"Elec_Grid\", marginal_cost=60, p_nom_extendable=True)\n","        c_args[\"bus3\"] = \"Elec_Grid\"\n","        c_args[\"efficiency3\"] = charge_thermo[\"eff_Elec_in\"]\n","        d_args[\"bus3\"] = \"Elec_Grid\"\n","        d_args[\"efficiency3\"] = discharge_thermo[\"eff_Elec_in\"]\n","\n","    # Layer 3 Args (Thermal)\n","    if layer == 3:\n","        n.add(\"Bus\", \"Heat_Low_Grid\", carrier=\"heat\")\n","        n.add(\"Bus\", \"Heat_High_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Sell_Low_Heat\", bus=\"Heat_Low_Grid\", marginal_cost=-10, sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Buy_High_Heat\", bus=\"Heat_High_Grid\", marginal_cost=35, p_nom_extendable=True)\n","\n","        c_args[\"bus4\"] = \"Heat_Low_Grid\"\n","        c_args[\"efficiency4\"] = charge_thermo[\"eff_Heat_out\"]\n","        d_args[\"bus4\"] = \"Heat_High_Grid\"\n","        d_args[\"efficiency4\"] = discharge_thermo[\"eff_Heat_in\"]\n","\n","    n.add(\"Link\", \"LOHC_Charge\", **c_args)\n","    n.add(\"Link\", \"LOHC_Discharge\", **d_args)\n","    return n\n","\n","# ==========================================\n","# 3. EXECUTION\n","# ==========================================\n","print(\"--- Step 1: Calculating Thermodynamics ---\")\n","# Adjust these temperatures to see the heat requirements shift!\n","chg_ratios, dischg_ratios = get_lohc_thermo(T_charge_C=150, T_discharge_C=320)\n","\n","print(\"Charge Ratios (Per 1 MWh H2):\", chg_ratios)\n","print(\"Discharge Ratios (Per 1 Tonne MCH):\", dischg_ratios)\n","print(\"\\n\" + \"=\"*50)\n","\n","print(\"Running PyPSA LOHC Optimization...\")\n","final_network = None\n","for layer in [1, 2, 3]:\n","    n = build_dynamic_lohc_network(layer, chg_ratios, dischg_ratios)\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","    if status[0] == \"ok\":\n","        print(f\"✅ Layer {layer} Optimized | System Cost: €{n.objective:,.2f}\")\n","        if layer == 3:\n","            final_network = n\n","    else:\n","        print(f\"❌ Layer {layer} failed.\")\n","\n","print(\"\\n\" + \"=\"*50)\n","print(\"LAYER 3 BREAKDOWN: Delivering 100 MWh of H2 via LOHC\")\n","print(\"-\" * 50)\n","\n","h2_cost = final_network.generators_t.p[\"H2_Source\"].iloc[0] * 90\n","tol_cost = final_network.generators_t.p[\"Toluene_Market\"].iloc[0] * 5\n","elec_cost = final_network.generators_t.p[\"Grid_Power\"].iloc[0] * 60\n","heat_bought = final_network.generators_t.p[\"Buy_High_Heat\"].iloc[0] * 35\n","heat_sold = final_network.generators_t.p[\"Sell_Low_Heat\"].iloc[0] * -10\n","\n","print(f\"1. Raw H2 Purchased:           €{h2_cost:,.2f}\")\n","print(f\"2. Initial Carrier (Toluene):  €{tol_cost:,.2f}\")\n","print(f\"3. Electricity (Pumps/Comp):   €{elec_cost:,.2f}\")\n","print(f\"4. High-Temp Heat (Discharge): €{heat_bought:,.2f}\")\n","print(f\"5. Low-Temp Heat Revenue:     -€{abs(heat_sold):,.2f}\")\n","print(\"-\" * 50)\n","print(f\"TOTAL SYSTEM COST:             €{final_network.objective:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ky6Une0AKCYK","executionInfo":{"status":"ok","timestamp":1773310353168,"user_tz":-60,"elapsed":4372,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"99c1c422-4722-4e33-a457-5e97a2a1534d"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["--- Step 1: Calculating Thermodynamics ---\n","Charge Ratios (Per 1 MWh H2): {'eff_MCH_out': 0.4866, 'eff_TOL_in': -0.4567, 'eff_Heat_out': 0.2892, 'eff_Elec_in': -0.05}\n","Discharge Ratios (Per 1 Tonne MCH): {'eff_H2_out': 2.0549, 'eff_TOL_out': 0.9384, 'eff_Heat_in': -0.6536, 'eff_Elec_in': -0.1}\n","\n","==================================================\n","Running PyPSA LOHC Optimization...\n","✅ Layer 1 Optimized | System Cost: €9,000.81\n","✅ Layer 2 Optimized | System Cost: €9,592.82\n","✅ Layer 3 Optimized | System Cost: €10,416.84\n","\n","==================================================\n","LAYER 3 BREAKDOWN: Delivering 100 MWh of H2 via LOHC\n","--------------------------------------------------\n","1. Raw H2 Purchased:           €9,000.77\n","2. Initial Carrier (Toluene):  €0.04\n","3. Electricity (Pumps/Comp):   €592.01\n","4. High-Temp Heat (Discharge): €1,113.24\n","5. Low-Temp Heat Revenue:     -€289.22\n","--------------------------------------------------\n","TOTAL SYSTEM COST:             €10,416.84\n"]}]},{"cell_type":"markdown","source":["# Fischer-Tropsch Synthetic Fuel Synthesis\n","\n","Generation of e-diesel and e-korosine from syngas"],"metadata":{"id":"ZowQ8NuVhB1c"}},{"cell_type":"code","source":["import pypsa\n","import logging\n","import pandas as pd\n","\n","# Mute logging for clarity\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","def build_ptl_network(layer):\n","    n = pypsa.Network()\n","\n","    # --- 0. CARRIERS (Fixes Consistency Warnings) ---\n","    # Explicitly define ALL carriers used in buses, generators, and links\n","    carriers = [\"hydrogen\", \"CO\", \"kerosene\", \"diesel\", \"water\", \"heat\"]\n","    for c in carriers:\n","        n.add(\"Carrier\", c)\n","\n","    # --- 1. BUSES ---\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"CO_Grid\", carrier=\"CO\")\n","    n.add(\"Bus\", \"e_Kerosene_Grid\", carrier=\"kerosene\")\n","    n.add(\"Bus\", \"e_Diesel_Grid\", carrier=\"diesel\")\n","\n","    # --- 2. GENERATORS (Supply) ---\n","    n.add(\"Generator\", \"H2_Supply\", bus=\"Hydrogen_Grid\", carrier=\"hydrogen\",\n","          marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Generator\", \"CO_Supply\", bus=\"CO_Grid\", carrier=\"CO\",\n","          marginal_cost=40, p_nom_extendable=True)\n","\n","    # --- 3. DEMANDS ---\n","    n.add(\"Load\", \"Aviation_Demand\", bus=\"e_Kerosene_Grid\", carrier=\"kerosene\", p_set=100)\n","    n.add(\"Load\", \"Transport_Demand\", bus=\"e_Diesel_Grid\", carrier=\"diesel\", p_set=80)\n","\n","    # --- 4. THE \"OVERFLOW\" SINKS (Prevents Infeasibility) ---\n","    # This allows the solver to \"dump\" excess fuel if the ratio is off\n","    n.add(\"Generator\", \"Kero_Sink\", bus=\"e_Kerosene_Grid\", carrier=\"kerosene\",\n","          marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","    n.add(\"Generator\", \"Diesel_Sink\", bus=\"e_Diesel_Grid\", carrier=\"diesel\",\n","          marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","\n","    # --- 5. THE REFINERY ---\n","    if layer == 1:\n","        n.add(\"Link\", \"PTL_Refinery\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"e_Kerosene_Grid\", bus2=\"e_Diesel_Grid\", bus3=\"CO_Grid\",\n","              efficiency=0.65, efficiency2=0.60, efficiency3=-1.10,\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        # Water Sink\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", carrier=\"water\",\n","              marginal_cost=2, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"PTL_Refinery\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"e_Kerosene_Grid\", bus2=\"e_Diesel_Grid\",\n","              bus3=\"CO_Grid\", bus4=\"Water_Grid\",\n","              efficiency=0.65, efficiency2=0.60, efficiency3=-1.10, efficiency4=0.15,\n","              p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", carrier=\"water\",\n","              marginal_cost=2, sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Heat_Export\", bus=\"Heat_Grid\", carrier=\"heat\",\n","              marginal_cost=-15, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"PTL_Refinery\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"e_Kerosene_Grid\", bus2=\"e_Diesel_Grid\",\n","              bus3=\"CO_Grid\", bus4=\"Water_Grid\", bus5=\"Heat_Grid\",\n","              efficiency=0.65, efficiency2=0.60, efficiency3=-1.10, efficiency4=0.15, efficiency5=0.42,\n","              p_nom_extendable=True)\n","\n","    return n\n","\n","# 6. RUN AND COMPARE\n","results = []\n","for name, layer in {\"ptl1 (Energy)\": 1, \"ptl2 (Mass)\": 2, \"ptl3 (Heat)\": 3}.items():\n","    n = build_ptl_network(layer)\n","\n","    # Fix FutureWarning by explicitly setting include_objective_constant\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","\n","    if status[0] == \"ok\":\n","        print(f\"\\u2705 {name} optimized! Total Cost: \\u20ac{n.objective:.2f}\")\n","        results.append({\"Network\": name, \"Total Cost (\\u20ac)\": n.objective})\n","    else:\n","        print(f\"\\u274c {name} failed: {status[0]}\")\n","\n","# Optional: Display clean table\n","df = pd.DataFrame(results)\n","display(df)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":195},"id":"uemJgCK0hG_j","executionInfo":{"status":"ok","timestamp":1773310359030,"user_tz":-60,"elapsed":5846,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"2ad44013-9c8d-41cd-8f50-f59d0efb4f30"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ ptl1 (Energy) optimized! Total Cost: €32923.08\n","✅ ptl2 (Mass) optimized! Total Cost: €32969.23\n","✅ ptl3 (Heat) optimized! Total Cost: €32000.00\n"]},{"output_type":"display_data","data":{"text/plain":["         Network  Total Cost (€)\n","0  ptl1 (Energy)    32923.076923\n","1    ptl2 (Mass)    32969.230769\n","2    ptl3 (Heat)    32000.000000"],"text/html":["\n","  <div id=\"df-158a9e39-0c08-4dcf-b8aa-eb67d1bbb003\" class=\"colab-df-container\">\n","    <div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>Network</th>\n","      <th>Total Cost (€)</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>ptl1 (Energy)</td>\n","      <td>32923.076923</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>ptl2 (Mass)</td>\n","      <td>32969.230769</td>\n","    </tr>\n","    <tr>\n","      <th>2</th>\n","      <td>ptl3 (Heat)</td>\n","      <