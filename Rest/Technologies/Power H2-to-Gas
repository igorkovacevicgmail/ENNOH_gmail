at_Grid\",\n","              efficiency=1.15, efficiency2=-0.45, efficiency3=0.18, efficiency4=0.45,\n","              p_nom_extendable=True)\n","\n","    return n"],"metadata":{"id":"HYnK7Jn3cpjt"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# 6. RUN AND COMPARE\n","networks = {\"meth1\": 1, \"meth2\": 2, \"meth3\": 3}\n","results = {}\n","\n","for name, layer in networks.items():\n","    n = build_methanation_network(layer)\n","    # Set include_objective_constant=True to suppress FutureWarning\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","    if status[0] == \"ok\":\n","        results[name] = n.objective\n","        print(f\"\\u2705 {name} optimized successfully.\")\n","    else:\n","        print(f\"\\u274c {name} failed: {status[0]}\")\n","\n","print(\"\\n\" + \"=\"*45)\n","print(f\"{'Network':<15} | {'Total System Cost (\\u20ac)':<20}\")\n","print(\"-\" * 45)\n","for k, v in results.items():\n","    print(f\"{k:<15} | {v:<20.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"mkm3gRSXdPjc","executionInfo":{"status":"ok","timestamp":1773246604562,"user_tz":-60,"elapsed":3469,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"e70c937c-18e3-41da-da11-e812e83d813f"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ meth1 optimized successfully.\n","✅ meth2 optimized successfully.\n","✅ meth3 optimized successfully.\n","\n","=============================================\n","Network         | Total System Cost (€)\n","---------------------------------------------\n","meth1           | 9391.30             \n","meth2           | 9422.61             \n","meth3           | 8640.00             \n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"CkWZ8SSsttzZ"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["## Sabatier Reaction"],"metadata":{"id":"1div81QPtuqM"}},{"cell_type":"code","source":["import pypsa\n","import logging\n","import pandas as pd\n","\n","# Mute logging for clean output\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","def build_sabatier_network(layer):\n","    n = pypsa.Network()\n","\n","    # Define carriers to fix consistency warnings\n","    for c in [\"hydrogen\", \"CO2\", \"methane\", \"water\", \"heat\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # ==========================================\n","    # 1. CORE GRIDS\n","    # ==========================================\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"CO2_Grid\", carrier=\"CO2\")\n","    n.add(\"Bus\", \"SNG_Grid\", carrier=\"methane\")\n","\n","    # Supplies & Demands\n","    n.add(\"Generator\", \"H2_Supply\", bus=\"Hydrogen_Grid\", carrier=\"hydrogen\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Generator\", \"CO2_Supply\", bus=\"CO2_Grid\", carrier=\"CO2\", marginal_cost=80, p_nom_extendable=True)\n","    n.add(\"Load\", \"SNG_Demand\", bus=\"SNG_Grid\", carrier=\"methane\", p_set=100)\n","    n.add(\"Generator\", \"SNG_Sink\", bus=\"SNG_Grid\", carrier=\"methane\", marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","\n","    # ==========================================\n","    # 2. THE SABATIER LAYERS\n","    # ==========================================\n","    if layer == 1:\n","        n.add(\"Link\", \"Sabatier_Plant\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"SNG_Grid\", bus2=\"CO2_Grid\",\n","              efficiency=0.83, efficiency2=-0.164, p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", carrier=\"water\", marginal_cost=2, sign=-1, p_nom_extendable=True)\n","        n.add(\"Link\", \"Sabatier_Plant\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"SNG_Grid\", bus2=\"CO2_Grid\", bus3=\"Water_Grid\",\n","              efficiency=0.83, efficiency2=-0.164, efficiency3=0.134, p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", carrier=\"water\", marginal_cost=2, sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Heat_Sales\", bus=\"Heat_Grid\", carrier=\"heat\", marginal_cost=-15, sign=-1, p_nom_extendable=True)\n","        n.add(\"Link\", \"Sabatier_Plant\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"SNG_Grid\", bus2=\"CO2_Grid\", bus3=\"Water_Grid\", bus4=\"Heat_Grid\",\n","              efficiency=0.83, efficiency2=-0.164, efficiency3=0.134, efficiency4=0.17, p_nom_extendable=True)\n","\n","    return n\n","\n","networks = {\"sabatier1\": 1, \"sabatier2\": 2, \"sabatier3\": 3}\n","results = {}\n","\n","print(\"Running PyPSA Sabatier Optimization...\")\n","for name, layer in networks.items():\n","    n = build_sabatier_network(layer)\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","    if status[0] == \"ok\":\n","        results[name] = n.objective\n","        print(f\"\\u2705 {name} optimized.\")\n","\n","print(\"\\n\" + \"=\"*50)\n","print(f\"{'Network':<15} | {'Total System Cost (\\u20ac)':<20}\")\n","print(\"-\" * 50)\n","for k, v in results.items():\n","    print(f\"{k:<15} | \\u20ac{v:<20.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vl2Pv6cntt2X","executionInfo":{"status":"ok","timestamp":1773246607827,"user_tz":-60,"elapsed":3194,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"32642281-4ce7-4989-ce9e-6011e085a352"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Running PyPSA Sabatier Optimization...\n","✅ sabatier1 optimized.\n","✅ sabatier2 optimized.\n","✅ sabatier3 optimized.\n","\n","==================================================\n","Network         | Total System Cost (€)\n","--------------------------------------------------\n","sabatier1       | €12424.10            \n","sabatier2       | €12456.39            \n","sabatier3       | €12149.16            \n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"ChERfi3btt8V"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# ADDING THERMODYNAMICAL DATABASE\n","## Cantera"],"metadata":{"id":"8c8GhsgagXuI"}},{"cell_type":"code","source":["!pip install cantera"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"76VuHe8dhN36","executionInfo":{"status":"ok","timestamp":1773246611840,"user_tz":-60,"elapsed":4001,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"986ec694-b92d-4962-d110-3d846dc4d65e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: cantera in /usr/local/lib/python3.12/dist-packages (3.2.0)\n","Requirement already satisfied: numpy<3,>=1.21.0 in /usr/local/lib/python3.12/dist-packages (from cantera) (2.0.2)\n","Requirement already satisfied: ruamel.yaml<1,>=0.17.21 in /usr/local/lib/python3.12/dist-packages (from cantera) (0.19.1)\n","Requirement already satisfied: typing_extensions>=4.13.0 in /usr/local/lib/python3.12/dist-packages (from cantera) (4.15.0)\n"]}]},{"cell_type":"code","source":["import cantera as ct\n","import pypsa\n","import pandas as pd\n","import logging\n","\n","# Mute PyPSA logging for a clean output\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","# ==========================================\n","# 1. THE THERMODYNAMIC ENGINE (Verified)\n","# ==========================================\n","def get_cantera_methanation_ratios(T_celsius=300):\n","    \"\"\"\n","    Calculates stoichiometric energy and mass ratios for:\n","    CO + 3H2 -> CH4 + H2O\n","    \"\"\"\n","    # Load NASA database (gri30 is the standard)\n","    try:\n","        gas = ct.Solution('gri30.yaml')\n","    except Exception:\n","        # Fallback for different Cantera versions\n","        gas = ct.Solution('ideal-gas.yaml')\n","\n","    gas.TP = T_celsius + 273.15, ct.one_atm\n","\n","    # Get Molar Masses (kg/kmol)\n","    mw = gas.molecular_weights\n","    idx = {s: gas.species_index(s) for s in ['H2', 'CO', 'CH4', 'H2O']}\n","\n","    # Stoichiometry (moles)\n","    moles = {'H2': 3, 'CO': 1, 'CH4': 1, 'H2O': 1}\n","\n","    # Energy Calculation (LHV Basis)\n","    # Standard LHVs in MJ/kg\n","    lhv_mj_kg = {'H2': 120.1, 'CO': 10.1, 'CH4': 50.0}\n","\n","    # Energy per reaction unit (MWh)\n","    # (moles * MW / 1000) * (MJ_kg / 3600)\n","    energy_mwh = {s: (moles[s] * mw[idx[s]] / 1000) * (lhv_mj_kg[s] / 3600)\n","                  for s in ['H2', 'CO', 'CH4']}\n","\n","    # Heat Release Calculation (Layer 3)\n","    # Using enthalpy of formation/sensible heat from NASA database\n","    h = gas.partial_molar_enthalpies # J/kmol\n","    delta_H_j = (moles['CH4']*h[idx['CH4']] + moles['H2O']*h[idx['H2O']]) - \\\n","                (moles['CO']*h[idx['CO']] + moles['H2']*h[idx['H2']])\n","\n","    # Convert J to MWh (1 J = 2.77e-10 MWh)\n","    heat_mwh = abs(delta_H_j) / 3.6e9 / 1000\n","\n","    # Normalize to 1 MWh of H2 (The PyPSA Bus0 unit)\n","    ref = energy_mwh['H2']\n","\n","    return {\n","        \"eff_CH4\":  round(energy_mwh['CH4'] / ref, 4),\n","        \"eff_CO\":   round(-(energy_mwh['CO'] / ref), 4),\n","        \"eff_Water\": round((moles['H2O'] * mw[idx['H2O']] / 1000) / ref, 4), # t/MWh_H2\n","        \"eff_Heat\": round(heat_mwh / ref, 4)\n","    }\n"],"metadata":{"id":"Jdigv-6whJSa"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ==========================================\n","# 2. THE PYPSA 3-LAYER MODEL (Improved to avoid warnings)\n","# ==========================================\n","def run_3_layer_simulation(thermo_data):\n","    summary = []\n","\n","    for layer in [1, 2, 3]:\n","        n = pypsa.Network()\n","\n","        # Define carriers to fix consistency warnings\n","        for c in [\"hydrogen\", \"CO\", \"methane\", \"water\", \"heat\"]:\n","            n.add(\"Carrier\", c)\n","\n","        n.add(\"Bus\", \"H2_Bus\", carrier=\"hydrogen\")\n","        n.add(\"Bus\", \"CO_Bus\", carrier=\"CO\")\n","        n.add(\"Bus\", \"SNG_Bus\", carrier=\"methane\")\n","\n","        # Add Suppliers\n","        n.add(\"Generator\", \"H2_Gen\", bus=\"H2_Bus\", carrier=\"hydrogen\", marginal_cost=90, p_nom_extendable=True)\n","        n.add(\"Generator\", \"CO_Gen\", bus=\"CO_Bus\", carrier=\"CO\", marginal_cost=40, p_nom_extendable=True)\n","\n","        # Demand\n","        n.add(\"Load\", \"SNG_Load\", bus=\"SNG_Bus\", carrier=\"methane\", p_set=100)\n","\n","        # Link Setup\n","        link_args = {\n","            \"bus0\": \"H2_Bus\",\n","            \"bus1\": \"SNG_Bus\",\n","            \"bus2\": \"CO_Bus\",\n","            \"efficiency\": thermo_data[\"eff_CH4\"],\n","            \"efficiency2\": thermo_data[\"eff_CO\"],\n","            \"p_nom_extendable\": True\n","        }\n","\n","        if layer >= 2:\n","            n.add(\"Bus\", \"Water_Bus\", carrier=\"water\")\n","            n.add(\"Generator\", \"Water_Sink\", bus=\"Water_Bus\", carrier=\"water\", marginal_cost=2, sign=-1, p_nom_extendable=True)\n","            link_args[\"bus3\"] = \"Water_Bus\"\n","            link_args[\"efficiency3\"] = thermo_data[\"eff_Water\"]\n","\n","        if layer == 3:\n","            n.add(\"Bus\", \"Heat_Bus\", carrier=\"heat\")\n","            n.add(\"Generator\", \"Heat_Buyer\", bus=\"Heat_Bus\", carrier=\"heat\", marginal_cost=-15, sign=-1, p_nom_extendable=True)\n","            link_args[\"bus4\"] = \"Heat_Bus\"\n","            link_args[\"efficiency4\"] = thermo_data[\"eff_Heat\"]\n","\n","        n.add(\"Link\", \"Methanator\", **link_args)\n","\n","        # Solve with include_objective_constant=True to suppress FutureWarning\n","       