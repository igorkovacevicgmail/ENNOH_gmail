CO_Grid\", carrier=\"CO\",\n","          marginal_cost=40, p_nom_extendable=True)\n","\n","    # --- 3. DEMANDS ---\n","    n.add(\"Load\", \"Aviation_Demand\", bus=\"e_Kerosene_Grid\", carrier=\"kerosene\", p_set=100)\n","    n.add(\"Load\", \"Transport_Demand\", bus=\"e_Diesel_Grid\", carrier=\"diesel\", p_set=80)\n","\n","    # --- 4. THE \"OVERFLOW\" SINKS (Prevents Infeasibility) ---\n","    # This allows the solver to \"dump\" excess fuel if the ratio is off\n","    n.add(\"Generator\", \"Kero_Sink\", bus=\"e_Kerosene_Grid\", carrier=\"kerosene\",\n","          marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","    n.add(\"Generator\", \"Diesel_Sink\", bus=\"e_Diesel_Grid\", carrier=\"diesel\",\n","          marginal_cost=1000, sign=-1, p_nom_extendable=True)\n","\n","    # --- 5. THE REFINERY ---\n","    if layer == 1:\n","        n.add(\"Link\", \"PTL_Refinery\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"e_Kerosene_Grid\", bus2=\"e_Diesel_Grid\", bus3=\"CO_Grid\",\n","              efficiency=0.65, efficiency2=0.60, efficiency3=-1.10,\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        # Water Sink\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", carrier=\"water\",\n","              marginal_cost=2, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"PTL_Refinery\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"e_Kerosene_Grid\", bus2=\"e_Diesel_Grid\",\n","              bus3=\"CO_Grid\", bus4=\"Water_Grid\",\n","              efficiency=0.65, efficiency2=0.60, efficiency3=-1.10, efficiency4=0.15,\n","              p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Water_Drain\", bus=\"Water_Grid\", carrier=\"water\",\n","              marginal_cost=2, sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Heat_Export\", bus=\"Heat_Grid\", carrier=\"heat\",\n","              marginal_cost=-15, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"PTL_Refinery\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"e_Kerosene_Grid\", bus2=\"e_Diesel_Grid\",\n","              bus3=\"CO_Grid\", bus4=\"Water_Grid\", bus5=\"Heat_Grid\",\n","              efficiency=0.65, efficiency2=0.60, efficiency3=-1.10, efficiency4=0.15, efficiency5=0.42,\n","              p_nom_extendable=True)\n","\n","    return n\n","\n","# 6. RUN AND COMPARE\n","results = []\n","for name, layer in {\"ptl1 (Energy)\": 1, \"ptl2 (Mass)\": 2, \"ptl3 (Heat)\": 3}.items():\n","    n = build_ptl_network(layer)\n","\n","    # Fix FutureWarning by explicitly setting include_objective_constant\n","    status = n.optimize(solver_name='highs', include_objective_constant=True)\n","\n","    if status[0] == \"ok\":\n","        print(f\"\\u2705 {name} optimized! Total Cost: \\u20ac{n.objective:.2f}\")\n","        results.append({\"Network\": name, \"Total Cost (\\u20ac)\": n.objective})\n","    else:\n","        print(f\"\\u274c {name} failed: {status[0]}\")\n","\n","# Optional: Display clean table\n","df = pd.DataFrame(results)\n","display(df)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":195},"id":"JuNhtskXT22L","executionInfo":{"status":"ok","timestamp":1773246601054,"user_tz":-60,"elapsed":11313,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"77b28eda-6a70-4fdb-82c7-f1468b0dd396"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["✅ ptl1 (Energy) optimized! Total Cost: €32923.08\n","✅ ptl2 (Mass) optimized! Total Cost: €32969.23\n","✅ ptl3 (Heat) optimized! Total Cost: €32000.00\n"]},{"output_type":"display_data","data":{"text/plain":["         Network  Total Cost (€)\n","0  ptl1 (Energy)    32923.076923\n","1    ptl2 (Mass)    32969.230769\n","2    p