ules>=0.2.1->google-auth<3.0.0,>=2.26.1->google-cloud-storage->linopy>=0.6.1->pypsa) (0.6.2)\n"]}]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive', force_remount=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0j36E6I_EntG","executionInfo":{"status":"ok","timestamp":1773307386539,"user_tz":-60,"elapsed":3805,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"45e949ab-c989-43bb-a4d9-bc8b4bd3a946"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["import os\n","import sys\n","ROOT_DIR = os.getcwd()\n","PROJECT_DIR = os.path.join(ROOT_DIR, \"drive/MyDrive/Colab_Notebooks/PyPSA/\")"],"metadata":{"id":"VLmwOE9AEoXp","executionInfo":{"status":"ok","timestamp":1773307386540,"user_tz":-60,"elapsed":2,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}}},"execution_count":3,"outputs":[]},{"cell_type":"markdown","source":["# Hydrogen Boilers"],"metadata":{"id":"opj0GfEYQKPR"}},{"cell_type":"markdown","source":["Because a Hydrogen Boiler's primary purpose is to generate heat, we don't need a third layer. The \"waste heat\" from our previous models is now the main product!\n","\n","However, moving from Layer 1 to Layer 2 here is incredibly interesting. It represents the engineering upgrade from a Standard Boiler to a Condensing Boiler."],"metadata":{"id":"PzmoJ2r7Qc__"}},{"cell_type":"markdown","source":["## Hard-Coded Efficiencies"],"metadata":{"id":"GiFoiuhtIqIk"}},{"cell_type":"code","source":["import pypsa\n","import logging\n","import pandas as pd\n","\n","# Mute PyPSA logging\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","def build_h2_boiler_network(layer):\n","    n = pypsa.Network()\n","\n","    # Define carriers to fix consistency warnings\n","    for c in [\"hydrogen\", \"heat\", \"water\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # ==========================================\n","    # 1. CORE GRIDS\n","    # ==========================================\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")  # MWh\n","    n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")      # MWh Thermal\n","\n","    # Supply and Demand\n","    n.add(\"Generator\", \"H2_Supply\", bus=\"Hydrogen_Grid\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Load\", \"District_Heating\", bus=\"Heat_Grid\", p_set=100) # We need 100 MWh of Heat\n","\n","    # ==========================================\n","    # 2. THE BOILER LAYERS\n","    # ==========================================\n","    if layer == 1:\n","        # Layer 1: Standard Boiler (Energy Only)\n","        # Water escapes as vapor out the exhaust stack, low heating value.\n","        n.add(\"Link\", \"H2_Boiler\",\n","              bus0=\"Hydrogen_Grid\",\n","              bus1=\"Heat_Grid\",\n","              efficiency=0.95,      # 95% LHV Efficiency\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        # Layer 2: Condensing Boiler (Energy + Mass)\n","        # Exhaust is cooled to condense water, recovering latent heat!\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")  # Tonnes\n","\n","        # Pure distilled water from burning H2 is valuable; we can sell it or reuse it.\n","        n.add(\"Generator\", \"Water_Sales\", bus=\"Water_Grid\", marginal_cost=-3, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"H2_Boiler\",\n","              bus0=\"Hydrogen_Grid\",\n","              bus1=\"Heat_Grid\",\n","              bus2=\"Water_Grid\",\n","              efficiency=1.05,      # 105% LHV Efficiency due to latent heat recovery\n","              efficiency2=0.268,    # Yields 0.268 tonnes of water per MWh of H2\n","              p_nom_extendable=True)\n","\n","    n.sanitize()\n","    return n\n","\n"],"metadata":{"id":"JuNhtskXT22L","executionInfo":{"status":"ok","timestamp":1773307397643,"user_tz":-60,"elapsed":11083,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["# ==========================================\n","# 3. EXECUTION & ECONOMIC COMPARISON\n","# ==========================================\n","networks = {\"Layer 1 (Standard)\": 1, \"Layer 2 (Condensing)\": 2}\n","final_network = None\n","\n","print(\"Running PyPSA Hydrogen Boiler Optimization...\\n\" + \"=\"*55)\n","\n","for name, layer in networks.items():\n","    n = build_h2_boiler_network(layer)\n","    status = n.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    if status[0] == \"ok\":\n","        print(f\"✅ {name:<22} | Total Heat Cost: €{n.objective:,.2f}\")\n","        if layer == 2:\n","            final_network = n\n","    else:\n","        print(f\"❌ {name} failed.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"prHzzCLXWbhd","executionInfo":{"status":"ok","timestamp":1773307400022,"user_tz":-60,"elapsed":2342,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"7761c997-1ec0-4dcc-b96b-4dbf9331dbd2"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Running PyPSA Hydrogen Boiler Optimization...\n","=======================================================\n","✅ Layer 1 (Standard)     | Total Heat Cost: €9,473.68\n","✅ Layer 2 (Condensing)   | Total Heat Cost: €8,494.86\n"]}]},{"cell_type":"code","source":["# ==========================================\n","# 4. LAYER 2 BREAKDOWN\n","# ==========================================\n","print(\"\\n\" + \"=\"*55)\n","print(\"LAYER 2 ECONOMICS: Delivering 100 MWh of Heat\")\n","print(\"-\" * 55)\n","\n","h2_cost = final_network.generators_t.p[\"H2_Supply\"].iloc[0] * 90\n","water_revenue = final_network.generators_t.p[\"Water_Sales\"].iloc[0] * -3\n","\n","print(f\"Hydrogen Purchased:      €{h2_cost:,.2f}\")\n","print(f\"Distilled Water Revenue: -€{abs(water_revenue):,.2f}\")\n","print(\"-\" * 55)\n","print(f\"NET SYSTEM COST:         €{final_network.objective:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"AWf4OWPGWbp3","executionInfo":{"status":"ok","timestamp":1773307400039,"user_tz":-60,"elapsed":4,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"f03f66fb-888c-4352-ed62-345c048be579"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=======================================================\n","LAYER 2 ECONOMICS: Delivering 100 MWh of Heat\n","-------------------------------------------------------\n","Hydrogen Purchased:      €8,571.43\n","Distilled Water Revenue: -€76.57\n","-------------------------------------------------------\n","NET SYSTEM COST:         €8,494.86\n"]}]},{"cell_type":"markdown","source":["## Cantera base incorporation"],"metadata":{"id":"8c8GhsgagXuI"}},{"cell_type":"code","source":["!pip install cantera"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"76VuHe8dhN36","executionInfo":{"status":"ok","timestamp":1773307404766,"user_tz":-60,"elapsed":4723,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"4b1e3155-373c-49f3-dd1c-377b53e6f44f"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: cantera in /usr/local/lib/python3.12/dist-packages (3.2.0)\n","Requirement already satisfied: numpy<3,>=1.21.0 in /usr/local/lib/python3.12/dist-packages (from cantera) (2.0.2)\n","Requirement already satisfied: ruamel.yaml<1,>=0.17.21 in /usr/local/lib/python3.12/dist-packages (from cantera) (0.19.1)\n","Requirement already satisfied: typing_extensions>=4.13.0 in /usr/local/lib/python3.12/dist-packages (from cantera) (4.15.0)\n"]}]},{"cell_type":"code","source":["import cantera as ct\n","import pypsa\n","import pandas as pd\n","import logging\n","\n","# 1. Mute PyPSA logging\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","# ==========================================\n","# 2. THE THERMODYNAMIC ENGINE (Combustion)\n","# ==========================================\n","def get_cantera_boiler_ratios(thermal_loss_factor=0.05):\n","    \"\"\"\n","    Calculates LHV and HHV heat yields for:\n","    H2 + 1/2 O2 -> H2O\n","    \"\"\"\n","    try:\n","        gas = ct.Solution('gri30.yaml')\n","    except Exception:\n","        gas = ct.Solution('ideal-gas.yaml')\n","\n","    # Standard reference temperature for heating values is 25°C\n","    gas.TP = 25 + 273.15, ct.one_atm\n","\n","    idx = {s: gas.species_index(s) for s in ['H2', 'O2', 'H2O']}\n","    mw = gas.molecular_weights\n","\n","    # 1. Stoichiometry (kmol)\n","    moles = {'H2': 1.0, 'O2': 0.5, 'H2O': 1.0}\n","\n","    # 2. LHV Enthalpy Calculation (Water remains as a Gas)\n","    h = gas.partial_molar_enthalpies # J/kmol\n","    delta_H_LHV = (moles['H2O']*h[idx['H2O']]) - (moles['H2']*h[idx['H2']] + moles['O2']*h[idx['O2']])\n","\n","    # 3. HHV Enthalpy Calculation (Water Condenses to Liquid)\n","    # Latent heat of vaporization for water at 25C is ~44.01 kJ/mol = 44,010 J/mol\n","    latent_heat_J = moles['H2O'] * 44010 * 1000 # Convert kJ/kmol to J/kmol\n","    delta_H_HHV = delta_H_LHV - latent_heat_J\n","\n","    # 4. Reference Input Energy (1 MWh of H2 on LHV basis)\n","    ref_energy_MWh = abs(delta_H_LHV) / 3.6e9\n","\n","    # 5. Calculate PyPSA Efficiencies (Incorporating physical boiler losses)\n","    # Eff = (Output Heat / Input Heat) * (1 - Casing Losses)\n","    eff_std = (abs(delta_H_LHV) / abs(delta_H_LHV)) * (1 - thermal_loss_factor)\n","    eff_cond = (abs(delta_H_HHV) / abs(delta_H_LHV)) * (1 - thermal_loss_factor)\n","\n","    # 6. Mass Calculation for Water (Tonnes)\n","    mass_water_tonnes = (moles['H2O'] * mw[idx['H2O']]) / 1000\n","\n","    return {\n","        \"eff_heat_std\":  round(eff_std, 4),\n","        \"eff_heat_cond\": round(eff_cond, 4),\n","        \"eff_water\":     round(mass_water_tonnes / ref_energy_MWh, 4)\n","    }\n"],"metadata":{"id":"Jdigv-6whJSa","executionInfo":{"status":"ok","timestamp":1773311549630,"user_tz":-60,"elapsed":21,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}}},"execution_count":12,"outputs":[]},{"cell_type":"code","source":["# ==========================================\n","# 3. THE PYPSA 2-LAYER MODEL\n","# ==========================================\n","def build_dynamic_boiler_network(layer, thermo):\n","    n = pypsa.Network()\n","\n","    # Define carriers to fix consistency warnings\n","    for c in [\"hydrogen\", \"heat\", \"water\"]:\n","        n.add(\"Carrier\", c)\n","\n","    # Grids\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","\n","    # Supply and Demand\n","    n.add(\"Generator\", \"H2_Supply\", bus=\"Hydrogen_Grid\", marginal_cost=90, p_nom_extendable=True)\n","    n.add(\"Load\", \"District_Heating\", bus=\"Heat_Grid\", p_set=100)\n","\n","    if layer == 1:\n","        n.add(\"Link\", \"H2_Boiler\",\n","              bus0=\"Hydrogen_Grid\",\n","              bus1=\"Heat_Grid\",\n","              efficiency=thermo[\"eff_heat_std\"],\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        n.add(\"Bus\", \"Water_Grid\", carrier=\"water\")\n","        n.add(\"Generator\", \"Water_Sales\", bus=\"Water_Grid\", marginal_cost=-3, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"H2_Boiler\",\n","              bus0=\"Hydrogen_Grid\",\n","              bus1=\"Heat_Grid\",\n","              bus2=\"Water_Grid\",\n","              efficiency=thermo[\"eff_heat_cond\"],\n","              efficiency2=thermo[\"eff_water\"],\n","              p_nom_extendable=True)\n","    n.sanitize()\n","    return n"],"metadata":{"id":"qkFOMqcbWod3","executionInfo":{"status":"ok","timestamp":1773311549685,"user_tz":-60,"elapsed":51,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}}},"execution_count":13,"outputs":[]},{"cell_type":"code","source":["# ==========================================\n","# 4. EXECUTION & OUTPUT\n","# ==========================================\n","print(\"--- Step 1: Verified Thermodynamics (Cantera) ---\")\n","thermo_data = get_cantera_boiler_ratios(thermal_loss_factor=0.05)\n","for k, v in thermo_data.items():\n","    print(f\"{k:<15}: {v}\")\n","print(\"\\n\" + \"=\"*55)\n","\n","print(\"Running PyPSA H2 Boiler Optimization...\")\n","final_network = None\n","for layer in [1, 2]:\n","    n = build_dynamic_boiler_network(layer, thermo_data)\n","    status = n.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    if status[0] == \"ok\":\n","        name = \"Layer 1 (Standard)\" if layer == 1 else \"Layer 2 (Condensing)\"\n","        print(f\"✅ {name:<22} | Total Heat Cost: €{n.objective:,.2f}\")\n","        if layer == 2:\n","            final_network = n\n","    else:\n","        print(f\"❌ Layer {layer} failed.\")\n","\n","if final_network:\n","    print(\"\\n\" + \"=\"*55)\n","    print(\"LAYER 2 ECONOMICS: Delivering 100 MWh of Heat\")\n","    print(\"-\" * 55)\n","    h2_cost = final_network.generators_t.p[\"H2_Supply\"].iloc[0] * 90\n","    water_revenue = final_network.generators_t.p[\"Water_Sales\"].iloc[0] * -3\n","\n","    print(f\"Hydrogen Purchased:      €{h2_cost:,.2f}\")\n","    print(f\"Distilled Water Revenue: -€{abs(water_revenue):,.2f}\")\n","    print(\"-\" * 55)\n","    print(f\"NET SYSTEM COST:         €{final_network.objective:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vbqoRoROWsKT","executionInfo":{"status":"ok","timestamp":1773311552508,"user_tz":-60,"elapsed":2821,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"176fa1c2-fb1c-4c84-938b-f47ecf544481"},"execution_count":14,"outputs":[{"output_type":"stream","name":"stdout","t