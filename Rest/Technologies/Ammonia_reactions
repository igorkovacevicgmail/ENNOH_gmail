xtendable=True)\n","    elif layer == 3:\n","        n.add(\"Bus\", \"Nitrogen_Atmosphere\", carrier=\"nitrogen\")\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","        n.add(\"Generator\", \"Nitrogen_Vent\", bus=\"Nitrogen_Atmosphere\", carrier=\"nitrogen\", sign=-1, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Industrial_Heater\", bus=\"Heat_Grid\", carrier=\"heat\", marginal_cost=35, p_nom_extendable=True)\n","        n.add(\"Link\", \"NH3_Cracker\", bus0=\"Ammonia_Grid\", bus1=\"Hydrogen_Grid\", bus2=\"Nitrogen_Atmosphere\", bus3=\"Heat_Grid\", efficiency=0.95, efficiency2=0.158, efficiency3=-0.15, p_nom_extendable=True)\n","\n","    n.optimize(solver_name='highs', include_objective_constant=True)\n","    return n.objective"],"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Running optimisation for three cases\n","AmCr_cost1 = build_ammonia_cracking_network(1)\n","AmCr_cost2 = build_ammonia_cracking_network(2)\n","AmCr_cost3 = build_ammonia_cracking_network(3)"],"metadata":{"id":"pbIVGbvUEu7t"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["print(f\"Layer 1 Cost: •{AmCr_cost1:.2f}\",\"<- Pure energy\")\n","print(f\"Layer 2 Cost: •{AmCr_cost2:.2f}\",\"<- Mass added (Nitrogen is free to vent)\")\n","print(f\"Layer 3 Cost: •{AmCr_cost3:.2f}\",\"<- Heat added (The true cost of the Boiler!)\")\n","print(f\"Additional Heat Cost: •{AmCr_cost3-AmCr_cost1:.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"AFAiujNeE_ck","executionInfo":{"status":"ok","timestamp":1773220579482,"user_tz":-60,"elapsed":13,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"53a0aa41-6057-42df-a898-e67c4e8e934b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Layer 1 Cost: •6315.79 <- Pure energy\n","Layer 2 Cost: •6315.79 <- Mass added (Nitrogen is free to vent)\n","Layer 3 Cost: •6868.42 <- Heat added (The true cost of the Boiler!)\n","Additional Heat Cost: •552.63\n"]}]},{"cell_type":"markdown","source":["# Hubber - Bosch Reaction"],"metadata":{"id":"6DH8Q6OdGMJW"}},{"cell_type":"code","source":["import pypsa\n","import logging\n","\n","# Mute the standard PyPSA logging to keep the console clean\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","def build_haber_bosch_network(layer):\n","    \"\"\"Builds a Haber-Bosch network based on the requested physics layer.\"\"\"\n","    n = pypsa.Network()\n","    n.add(\"Carrier\", [\"hydrogen\", \"ammonia\", \"nitrogen\", \"heat\"])\n","\n","    # ==========================================\n","    # 1. CORE GRIDS & DEMAND\n","    # ==========================================\n","    n.add(\"Bus\", \"Hydrogen_Grid\", carrier=\"hydrogen\")\n","    n.add(\"Bus\", \"Ammonia_Grid\", carrier=\"ammonia\")\n","\n","    # Buy pure hydrogen at •100 per MWh\n","    n.add(\"Generator\", \"Hydrogen_Supply\", bus=\"Hydrogen_Grid\", carrier=\"hydrogen\", marginal_cost=100, p_nom_extendable=True)\n","\n","    # We force the model to produce exactly 100 MWh of Liquid Ammonia\n","    n.add(\"Load\", \"Ammonia_Demand\", bus=\"Ammonia_Grid\", p_set=100)\n","\n","    # ==========================================\n","    # 2. THE PHYSICS LAYERS\n","    # ==========================================\n","    if layer == 1:\n","        # Layer 1: Energy Only\n","        n.add(\"Link\", \"Haber_Bosch_Plant\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"Ammonia_Grid\",\n","              efficiency=0.85,\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        # Layer 2: Energy + Mass (Nitrogen)\n","        n.add(\"Bus\", \"Nitrogen_Grid\", carrier=\"nitrogen\")\n","\n","        # We must run an Air Separation Unit (ASU) to get pure N2 (Costs •10/ton)\n","        n.add(\"Generator\", \"ASU_Plant\", bus=\"Nitrogen_Grid\", carrier=\"nitrogen\", marginal_cost=10, p_nom_extendable=True)\n","\n","        n.add(\"Link\", \"Haber_Bosch_Plant\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"Ammonia_Grid\", bus2=\"Nitrogen_Grid\",\n","              efficiency=0.85, efficiency2=-0.14,  # CONSUMES Nitrogen\n","              p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        # Layer 3: Energy + Mass + Heat\n","        n.add(\"Bus\", \"Nitrogen_Grid\", carrier=\"nitrogen\")\n","        n.add(\"Bus\", \"Heat_Grid\", carrier=\"heat\")\n","\n","        n.add(\"Generator\", \"ASU_Plant\", bus=\"Nitrogen_Grid\", carrier=\"nitrogen\", marginal_cost=10, p_nom_extendable=True)\n","\n","        # Heat management: If HB doesn't provide enough waste heat, buy from boiler.\n","        # If it provides too much, we need a sink (vent/cooling tower).\n","        n.add(\"Generator\", \"Industrial_Boiler\", bus=\"Heat_Grid\", carrier=\"heat\", marginal_cost=30, p_nom_extendable=True)\n","        n.add(\"Generator\", \"Cooling_Tower\", bus=\"Heat_Grid\", carrier=\"heat\", marginal_cost=0, sign=-1, p_nom_extendable=True)\n","\n","        n.add(\"Load\", \"Factory_Heat_Demand\", bus=\"Heat_Grid\", p_set=15)\n","\n","        n.add(\"Link\", \"Haber_Bosch_Plant\",\n","              bus0=\"Hydrogen_Grid\", bus1=\"Ammonia_Grid\",\n","              bus2=\"Nitrogen_Grid\", bus3=\"Heat_Grid\",\n","              efficiency=0.85, efficiency2=-0.14,\n","              efficiency3=0.15,  # PRODUCES Waste Heat\n","              p_nom_extendable=True)\n","\n","    n.optimize(solver_name='highs', include_objective_constant=True)\n","    return n.objective\n"],"metadata":{"id":"11pJU6UdGQL8"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Run the three layers\n","HB_cost1 = build_haber_bosch_network(1)\n","HB_cost2 = build_haber_bosch_network(2)\n","HB_cost3 = build_haber_bosch_network(3)\n"],"metadata":{"id":"Zzv5qwVLGQiT"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Print results\n","print(\"\\n\" + \"=\"*55)\n","print(\"HABER-BOSCH INDUSTRIAL PARK COSTS\")\n","print(\"=\"*55)\n","print(f\"Layer 1 (Energy):      •{HB_cost1:.2f}\")\n","print(f\"Layer 2 (Energy+Mass): •{HB_cost2:.2f} (ASU Cost added)\")\n","print(f\"Layer 3 (All Physics): •{HB_cost3:.2f} (Waste Heat offset)\")\n","print(\"-\" * 55)\n","print(f\"ASU Impact:           +•{HB_cost2-HB_cost1:.2f}\")\n","print(f\"Waste Heat Savings:    -•{HB_cost2-HB_cost3:.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"EUBxPFXDG1km","executionInfo":{"status":"ok","timestamp":1773220582914,"user_tz":-60,"elapsed":14,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"25f255d9-1eb0-4a01-a4af-e5ccc8c3d8ec"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=======================================================\n","HABER-BOSCH INDUSTRIAL PARK COSTS\n","=======================================================\n","Layer 1 (Energy):      •11764.71\n","Layer 2 (Energy+Mass): •11929.41 (ASU Cost added)\n","Layer 3 (All Physics): •11929.41 (Waste Heat offset)\n","-------------------------------------------------------\n","ASU Impact:           +•164.71\n","Waste Heat Savings:    -•0.00\n"]}]}]}