"colab":{"base_uri":"https://localhost:8080/"},"id":"5783cb20","executionInfo":{"status":"ok","timestamp":1774962198587,"user_tz":-120,"elapsed":1552,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"8a165745-a768-4d69-f051-42865243e6ed"},"source":["import pypsa\n","\n","# 1. Initialize n_atr2 using the builder for Layer 2\n","n_atr2 = build_total_atr(layer=2)\n","\n","# 2. Add Hydrogen Demand Load\n","n_atr2.add(\"Load\", \"Hydrogen_Demand\",\n","           bus=\"Hydrogen_Grid\",\n","           p_set=100)\n","\n","# 3. Add CO2 Storage\n","n_atr2.add(\"Store\", \"CO2_Storage\",\n","           bus=\"CO2_Grid\",\n","           e_nom_extendable=True,\n","           e_cyclic=False)\n","\n","# 4. Ensure generators have extendable capacity for methane, water, and oxygen\n","n_atr2.generators.loc[\"Gas_Pipeline\", \"p_nom_extendable\"] = True\n","n_atr2.generators.loc[\"City_Water\", \"p_nom_extendable\"] = True\n","n_atr2.generators.loc[\"ASU_Plant\", \"p_nom_extendable\"] = True\n","\n","# 5. Sanitize and 6. Optimize\n","try:\n","    n_atr2.sanitize()\n","    n_atr2.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    # 7. Results Extraction\n","    if n_atr2.objective is not None:\n","        snap = n_atr2.snapshots[0]\n","        # Link outputs: p1=H2, p3=Water, p4=Oxygen\n","        h2_prod = -n_atr2.links_t.p1.loc[snap, \"ATR_Total_Plant\"]\n","        water_cons = n_atr2.links_t.p3.loc[snap, \"ATR_Total_Plant\"]\n","        o2_cons = n_atr2.links_t.p4.loc[snap, \"ATR_Total_Plant\"]\n","\n","        print(f\"Optimization Successful!\")\n","        print(f\"Total Objective Value (Cost): •{n_atr2.objective:.2f}\")\n","        print(f\"Hydrogen Production: {h2_prod:.2f} MWh\")\n","        print(f\"Water Consumption:   {water_cons:.2f} m3\")\n","        print(f\"Oxygen Consumption:  {o2_cons:.2f} tons\")\n","    else:\n","        print(\"Optimization failed to find a solution.\")\n","except Exception as e:\n","    print(f\"An error occurred during optimization: {e}\")"],"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["Layer 2: Energy + Mass (Total ATR + Oxygen)\n","Optimization Successful!\n","Total Objective Value (Cost): •7863532.14\n","Hydrogen Production: 100.00 MWh\n","Water Consumption:   21.43 m3\n","Oxygen Consumption:  25.71 tons\n"]}]},{"cell_type":"markdown","metadata":{"id":"f3390e4b"},"source":["## Layer 3 (n_atr3)\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"21ce9989","executionInfo":{"status":"ok","timestamp":1774962200231,"user_tz":-120,"elapsed":1612,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"2d5fb484-adce-4dc5-edf2-92cab0cb46e4"},"source":["import pypsa\n","\n","# 1. Initialize n_atr3 using the builder for Layer 3\n","n_atr3 = build_total_atr(layer=3)\n","\n","# 2. Add Hydrogen Demand Load\n","n_atr3.add(\"Load\", \"Hydrogen_Demand\",\n","           bus=\"Hydrogen_Grid\",\n","           p_set=100)\n","\n","# 3. Add CO2 Storage\n","n_atr3.add(\"Store\", \"CO2_Storage\",\n","           bus=\"CO2_Grid\",\n","           e_nom_extendable=True,\n","           e_cyclic=False)\n","\n","# 4. Ensure generators have extendable capacity\n","gens_to_extend = [\"Gas_Pipeline\", \"City_Water\", \"ASU_Plant\", \"Aux_Boiler\"]\n","for gen in gens_to_extend:\n","    n_atr3.generators.loc[gen, \"p_nom_extendable\"] = True\n","\n","# 5. Sanitize and 6. Optimize\n","try:\n","    n_atr3.sanitize()\n","    n_atr3.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    # 7. Results Extraction and Printing\n","    if n_atr3.objective is not None:\n","        snap = n_atr3.snapshots[0]\n","        # Link outputs: p1=H2, p3=Water, p4=Oxygen, p5=Heat\n","        h2_prod = -n_atr3.links_t.p1.loc[snap, \"ATR_Total_Plant\"]\n","        water_cons = n_atr3.links_t.p3.loc[snap, \"ATR_Total_Plant\"]\n","        o2_cons = n_atr3.links_t.p4.loc[snap, \"ATR_Total_Plant\"]\n","        heat_cons = n_atr3.links_t.p5.loc[snap, \"ATR_Total_Plant\"]\n","\n","        print(f\"Optimization Successful!\")\n","        print(f\"Total Objective Value (Cost): •{n_atr3.objective:.2f}\")\n","        print(f\"Hydrogen Production: {h2_prod:.2f} MWh\")\n","        print(f\"Water Consumption:   {water_cons:.2f} m3\")\n","        print(f\"Oxygen Consumption:  {o2_cons:.2f} tons\")\n","        print(f\"Heat Consumption:    {heat_cons:.2f} MWh (Should be 0.0 for ATR)\")\n","    else:\n","        print(\"Optimization failed to find a solution.\")\n","except Exception as e:\n","    print(f\"An error occurred during optimization: {e}\")"],"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["Layer 3: Energy + Mass + Heat (Total ATR)\n","Optimization Successful!\n","Total Objective Value (Cost): •7863532.14\n","Hydrogen Production: 100.00 MWh\n","Water Consumption:   21.43 m3\n","Oxygen Consumption:  25.71 tons\n","Heat Consumption:    -0.00 MWh (Should be 0.0 for ATR)\n"]}]},{"cell_type":"markdown","metadata":{"id":"47ba6eb6"},"source":["## Summary:\n","\n","### Q&A\n","\n","**How does increasing model fidelity (Layer 1 to Layer 3) impact the ATR system analysis?**\n","Increasing fidelity allows for a more granular understanding of resource dependencies beyond just energy. While Layer 1 only tracks Methane and CO2, Layer 2 introduces the specific costs and quantities for Water and Oxygen consumption. Layer 3 further integrates thermal dynamics, confirming that the ATR unit is heat-neutral (self-sufficient) under the specified efficiency parameters.\n","\n","**What are the specific resource requirements for producing 100 MWh of Hydrogen?**\n","Based on the Layer 2 and 3 simulations:\n","*   **Methane (Fuel):** Sourced via the Gas Pipeline to meet the 70% efficiency conversion.\n","*   **Water:** 21.43 m³ consumed.\n","*   **Oxygen:** 25.71 tons consumed (supplied by the Air Separation Unit).\n","*   **CO2:** Produced at an efficiency of 0.224 relative to the primary bus and captured in storage.\n","*   **Heat:** 0.0 MWh (Self-generated/neutral).\n","\n","---\n","\n","### Data Analysis Key Findings\n","\n","*   **Total System Costs:** The objective value increased as more physical constraints were added.\n","    *   **Layer 1 (Energy-only):** \\$7,862,857.14\n","    *   **Layer 2 (Energy + Mass):** \\$7,863,532.14\n","    *   **Layer 3 (Energy + Mass + Heat):** \\$7,863,532.14\n","    *   *Note: The cost jump from Layer 1 to Layer 2 (\\$675.00) represents the marginal costs of Water ($1.5/m³) and Oxygen ($25/ton) required for the process.*\n","*   **Resource Neutrality in Layer 3:** By setting the heat efficiency to 0.0, the model confirmed the ATR’s ability to operate without external heat input from the Auxiliary Boiler, maintaining a heat consumption of exactly 0.00 MWh while still satisfying the 100 MWh Hydrogen load.\n","*   **Operational Bottlenecks:** Initial simulations failed (infeasible) because the Methane source lacked capacity; setting `p_nom_extendable=True` for all supply generators (Gas, Water, ASU) was necessary to achieve optimization.\n","\n","---\n","\n","### Insights or Next Steps\n","\n","*   **Sensitivity Analysis on Heat Efficiency:** Since Layer 3 currently assumes a heat-neutral process (0.0 efficiency), a valuable next step would be to adjust this efficiency to a negative value (representing external heat demand) or a positive value (representing waste heat recovery) to see how it affects the deployment of the Auxiliary Boiler or external heat markets.\n","*   **Carbon Tax Integration:** Given that CO2 is already being tracked in a dedicated storage unit, the model could be extended to include carbon pricing or emission limits to see how it affects the total cost of Hydrogen production compared to other technologies like electrolysis.\n"]}]}