,"n1.add(\"Bus\", \"Hydrogen_Grid\")\n","\n","# 3. Add Generator (Methane Source)\n","n1.add(\"Generator\", \"Gas_Pipeline\",\n","       bus=\"Methane_Grid\",\n","       marginal_cost=40,\n","       p_nom_extendable=True)\n","\n","# 4. Add Load (Hydrogen Demand)\n","n1.add(\"Load\", \"Hydrogen_Demand\",\n","       bus=\"Hydrogen_Grid\",\n","       p_set=100)\n","\n","# 5. Add Link (SMR Process Layer 1)\n","n1.add(\"Link\", \"SMR_Plant_L1\",\n","       bus0=\"Methane_Grid\",\n","       bus1=\"Hydrogen_Grid\",\n","       efficiency=0.79,\n","       p_nom_extendable=True)\n","\n","# 6. Sanitize and Optimize\n","try:\n","    n1.sanitize()\n","    n1.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    # 7. Results and Verification\n","    if n1.objective is not None:\n","        snap = n1.snapshots[0]\n","        h2_prod = -n1.links_t.p1.loc[snap, \"SMR_Plant_L1\"]\n","        print(f\"Optimization Successful!\")\n","        print(f\"Total Objective Value (Cost): €{n1.objective:.2f}\")\n","        print(f\"Hydrogen Production (bus1): {h2_prod:.2f} MWh\")\n","    else:\n","        print(\"Optimization failed to find an objective.\")\n","except Exception as e:\n","    print(f\"An error occurred during optimization: {e}\")"],"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Optimization Successful!\n","Total Objective Value (Cost): €5063.29\n","Hydrogen Production (bus1): 100.00 MWh\n"]}]},{"cell_type":"markdown","metadata":{"id":"970ac89e"},"source":["## Layer 2 Network (n2)\n","\n","### Subtask:\n","Initialize a new PyPSA network 'n2' to implement an Energy + Mass model, incorporating Water and CO2 constraints alongside the SMR process.\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"5255c5a8","executionInfo":{"status":"ok","timestamp":1774962193281,"user_tz":-120,"elapsed":2412,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"88459ecd-3fe1-4427-b259-3a440fe6f40f"},"source":["import pypsa\n","\n","# 1. Initialize a new PyPSA network object named 'n2'\n","n2 = pypsa.Network()\n","\n","# 2. Add four buses\n","buses = ['Methane_Grid', 'Hydrogen_Grid', 'CO2_Grid', 'Water_Grid']\n","for bus in buses:\n","    n2.add(\"Bus\", bus)\n","\n","# 3. Add two generators\n","n2.add(\"Generator\", \"Gas_Pipeline\", bus=\"Methane_Grid\", marginal_cost=40, p_nom_extendable=True)\n","n2.add(\"Generator\", \"City_Water\", bus=\"Water_Grid\", marginal_cost=1.5, p_nom_extendable=True)\n","\n","# 4. Add a load named 'Hydrogen_Demand'\n","n2.add(\"Load\", \"Hydrogen_Demand\", bus=\"Hydrogen_Grid\", p_set=100)\n","\n","# 5. Add a 4-bus 'Link' named 'SMR_Plant_L2'\n","n2.add(\"Link\", \"SMR_Plant_L2\",\n","       bus0=\"Methane_Grid\",\n","       bus1=\"Hydrogen_Grid\",\n","       bus2=\"CO2_Grid\",\n","       bus3=\"Water_Grid\",\n","       efficiency=0.79,           # H2 Production (Output)\n","       efficiency2=0.224,         # CO2 Production (Output)\n","       efficiency3=-0.292,        # Water Consumption (Input)\n","       p_nom_extendable=True)\n","\n","# 6. Add a 'Store' named 'CO2_Storage'\n","n2.add(\"Store\", \"CO2_Storage\", bus=\"CO2_Grid\", e_nom_extendable=True, e_cyclic=False)\n","\n","# 7. Sanitize and Optimize\n","try:\n","    n2.sanitize()\n","    n2.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    # 8. Print Results\n","    if n2.objective is not None:\n","        snap = n2.snapshots[0]\n","        # p1=H2, p2=CO2, p3=Water\n","        h2_prod = -n2.links_t.p1.loc[snap, \"SMR_Plant_L2\"]\n","        co2_emissions = -n2.links_t.p2.loc[snap, \"SMR_Plant_L2\"]\n","        water_cons = n2.links_t.p3.loc[snap, \"SMR_Plant_L2\"]\n","\n","        print(f\"Optimization Successful!\")\n","        print(f\"Total Objective Value (Cost): €{n2.objective:.2f}\")\n","        print(f\"Hydrogen Production: {h2_prod:.2f} MWh\")\n","        print(f\"CO2 Emissions:       {co2_emissions:.2f} tons\")\n","        print(f\"Water Consumption:   {water_cons:.2f} m3\")\n","    else:\n","        print(\"Optimization failed to find a solution.\")\n","except Exception as e:\n","    print(f\"An error occurred during optimization: {e}\")"],"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Optimization Successful!\n","Total Objective Value (Cost): €5118.73\n","Hydrogen Production: 100.00 MWh\n","CO2 Emissions:       28.35 tons\n","Water Consumption:   36.96 m3\n"]}]},{"cell_type":"markdown","metadata":{"id":"89963103"},"source":["## Layer 3 Network (n3)\n","\n","### Subtask:\n","Initialize a new PyPSA network 'n3' to implement a comprehensive Energy + Mass + Heat model, incorporating thermal energy constraints for the SMR process.\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ea2bcbf1","executionInfo":{"status":"ok","timestamp":1774962195509,"user_tz":-120,"elapsed":2220,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"12eefa7f-cfb6-45e7-a2e3-9a3dd6248aef"},"source":["import pypsa\n","\n","# 1. Initialize a new PyPSA network object named 'n3'\n","n3 = pypsa.Network()\n","\n","# 2. Add five buses\n","buses = ['Methane_Grid', 'Hydrogen_Grid', 'CO2_Grid', 'Water_Grid', 'Heat_Grid']\n","for bus in buses:\n","    n3.add(\"Bus\", bus)\n","\n","# 3. Add three generators\n","n3.add(\"Generator\", \"Gas_Pipeline\", bus=\"Methane_Grid\", marginal_cost=40, p_nom_extendable=True)\n","n3.add(\"Generator\", \"City_Water\", bus=\"Water_Grid\", marginal_cost=1.5, p_nom_extendable=True)\n","n3.add(\"Generator\", \"Aux_Boiler\", bus=\"Heat_Grid\", marginal_cost=30, p_nom_extendable=True)\n","\n","# 4. Add a load named 'Hydrogen_Demand'\n","n3.add(\"Load\", \"Hydrogen_Demand\", bus=\"Hydrogen_Grid\", p_set=100)\n","\n","# 5. Add a 5-bus 'Link' named 'SMR_Plant_L3'\n","n3.add(\"Link\", \"SMR_Plant_L3\",\n","       bus0=\"Methane_Grid\",\n","       bus1=\"Hydrogen_Grid\",\n","       bus2=\"CO2_Grid\",\n","       bus3=\"Water_Grid\",\n","       bus4=\"Heat_Grid\",\n","       efficiency=0.79,           # H2 Production\n","       efficiency2=0.224,         # CO2 Production\n","       efficiency3=-0.292,        # Water Consumption\n","       efficiency4=-0.210,        # Heat Consumption\n","       p_nom_extendable=True)\n","\n","# 6. Add a 'Store' named 'CO2_Storage'\n","n3.add(\"Store\", \"CO2_Storage\", bus=\"CO2_Grid\", e_nom_extendable=True, e_cyclic=False)\n","\n","# 7. Sanitize and Optimize\n","try:\n","    n3.sanitize()\n","    n3.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    # 8. Results Extraction and Printing\n","    if n3.objective is not None:\n","        snap = n3.snapshots[0]\n","        # p1=H2, p2=CO2, p3=Water, p4=Heat\n","        h2_prod = -n3.links_t.p1.loc[snap, \"SMR_Plant_L3\"]\n","        co2_emissions = -n3.links_t.p2.loc[snap, \"SMR_Plant_L3\"]\n","        water_cons = n3.links_t.p3.loc[snap, \"SMR_Plant_L3\"]\n","        heat_cons = n3.links_t.p4.loc[snap, \"SMR_Plant_L3\"]\n","\n","        print(f\"Optimization Successful!\")\n","        print(f\"Total Objective Value (Cost): €{n3.objective:.2f}\")\n","        print(f\"Hydrogen Production: {h2_prod:.2f} MWh\")\n","        print(f\"CO2 Emissions:       {co2_emissions:.2f} tons\")\n","        print(f\"Water Consumption:   {water_cons:.2f} m3\")\n","        print(f\"Heat Consumption:    {heat_cons:.2f} MWh\")\n","    else:\n","        print(\"Optimization failed to find a solution.\")\n","except Exception as e:\n","    print(f\"An error occurred during optimization: {e}\")"],"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Optimization Successful!\n","Total Objective Value (Cost): €5916.20\n","Hydrogen Production: 100.00 MWh\n","CO2 Emissions:       28.35 tons\n","Water Consumption:   36.96 m3\n","Heat Consumption:    26.58 MWh\n"]}]},{"cell_type":"markdown","metadata":{"id":"ef888929"},"source":["## Summary:\n","\n","This summary outlines the incremental development of a Steam Methane Reforming (SMR) process model across three levels of fidelity—from basic energy tracking to a comprehensive energy, mass, and heat balance model—to meet a 100 MWh hydrogen demand.\n","\n","### Q&A\n","\n","**How does increasing the model fidelity affect the calculated cost of hydrogen production?**\n","Increasing fidelity leads to a higher and more accurate total system cost. The baseline energy-only model (n1) estimated the cost at €5,063.29. Adding water consumption (n2) increased the cost to €5,118.73. Incorporating thermal energy requirements via an auxiliary boiler (n3) raised the total cost to €5,916.20, representing a ~16.8% increase from the baseline.\n","\n","**What resources are tracked at each stage of the model development?**\n","*   **Layer 1 (Energy):** Methane and Hydrogen.\n","*   **Layer 2 (Energy + Mass):** Methane, Hydrogen, CO2 (stored), and Water.\n","*   **Layer 3 (Energy + Mass + Heat):** Methane, Hydrogen, CO2, Water, and Thermal Energy (Heat).\n","\n","---\n","\n","### Data Analysis Key Findings\n","\n","*   **Layer 1 (Baseline):** A simple 79% efficiency conversion resulted in a methane-only cost of **€5,063.29** for 100 MWh of H2.\n","*   **Layer 2 (Mass Balance):** To produce the same 100 MWh of H2, the system required **36.96 m³ of water** and produced **28.35 tons of CO2**. The addition of water costs (marginal cost of 1.5) raised the total objective value to **€5,118.73**.\n","*   **Layer 3 (Full Fidelity):** The SMR process was found to consume **26.58 MWh of heat**. Providing this heat through an auxiliary boiler (marginal cost of 30) significantly impacted the budget, resulting in a total system cost of **€5,916.20**.\n","*   **SMR Link Efficiency Multipliers:** The transition from a 2-bus link to a 5-bus link successfully tracked multiple resource streams by using negative efficiencies for inputs (Water: -0.292, Heat: -0.210) and positive efficiencies for outputs (H2: 0.79, CO2: 0.224).\n","\n","---\n","\n","### Insights or Next Steps\n","\n","*   **Model Accuracy:** Simplified energy-only models significantly underestimate the operational expenses of hydrogen production. Future analyses should prioritize heat integration (e.g., using waste heat) to potentially lower the €5,916.20 total cost.\n","*   **Carbon Valuation:** The next logical step is to introduce a carbon tax or price on the 28.35 tons of CO2 produced to evaluate the economic viability of carbon capture and storage (CCS) compared to venting.\n"]},{"cell_type":"markdown","source":["# Autothermal Reforming"],"metadata":{"id":"uDUZwGoba8m9"}},{"cell_type":"code","source":["import pypsa\n","\n","def build_total_atr(layer=1):\n","    n = pypsa.Network()\n","\n","    # ==========================================\n","    # 1. CORE GRIDS (Always Active)\n","    # ==========================================\n","    n.add(\"Bus\", \"Methane_Grid\")\n","    n.add(\"Bus\", \"Hydrogen_Grid\")\n","    n.add(\"Bus\", \"CO2_Grid\")\n","\n","    n.add(\"Generator\", \"Gas_Pipeline\", bus=\"Methane_Grid\", marginal_cost=40)\n","\n","    # ==========================================\n","    # 2. THE PHYSICS LAYERS (ATR)\n","    # ==========================================\n","\n","    if layer == 1:\n","        print(\"Layer 1: Energy Only (Total ATR)\")\n","\n","        n.add(\"Link\", \"ATR_Total_Plant\",\n","              bus0=\"Methane_Grid\",\n","              bus1=\"Hydrogen_Grid\",\n","              bus2=\"CO2_Grid\",\n","\n","              efficiency=0.70,           # Produces H2\n","              efficiency2=0.224,         # Emits CO2 (All in one concentrated stream!)\n","\n","              capital_cost=55000,        # Cheaper CAPEX than SMR (no massive furnace)\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        print(\"Layer 2: Energy + Mass (Total ATR + Oxygen)\")\n","\n","        # Add Water and Oxygen Grids\n","        n.add(\"Bus\", \"Water_Grid\")\n","        n.add(\"Bus\", \"Oxygen_Grid\")\n","\n","        n.add(\"Generator\", \"City_Water\", bus=\"Water_Grid\", marginal_cost=1.5)\n","        # We add an Air Separation Unit (ASU) to provide the pure Oxygen\n","        n.add(\"Generator\", \"ASU_Plant\", bus=\"Oxygen_Grid\", marginal_cost=25)\n","\n","        n.add(\"Link\", \"ATR_Total_Plant\",\n","              bus0=\"Methane_Grid\",\n","              bus1=\"Hydrogen_Grid\",\n","              bus2=\"CO2_Grid\",\n","              bus3=\"Water_Grid\",\n","              bus4=\"Oxygen_Grid\",        # The new O2 connection\n","\n","              efficiency=0.70,\n","              efficiency2=0.224,\n","              efficiency3=-0.15,         # CONSUMES Water\n","              efficiency4=-0.18,         # CONSUMES Pure Oxygen\n","\n","              capital_cost=55000,\n","              p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        print(\"Layer 3: Energy + Mass + Heat (Total ATR)\")\n","\n","        # Add Water, Oxygen, and Heat Grids\n","        n.add(\"Bus\", \"Water_Grid\")\n","        n.add(\"Bus\", \"Oxygen_Grid\")\n","        n.add(\"Bus\", \"Heat_Grid\")\n","\n","        n.add(\"Generator\", \"City_Water\", bus=\"Water_Grid\", marginal_cost=1.5)\n","        n.add(\"Generator\", \"ASU_Plant\", bus=\"Oxygen_Grid\", marginal_cost=25)\n","        n.add(\"Generator\", \"Aux_Boiler\", bus=\"Heat_Grid\", marginal_cost=30)\n","\n","        n.add(\"Link\", \"ATR_Total_Plant\",\n","              bus0=\"Methane_Grid\",\n","              bus1=\"Hydrogen_Grid\",\n","              bus2=\"CO2_Grid\",\n","              bus3=\"Water_Grid\",\n","              bus4=\"Oxygen_Grid\",\n","              bus5=\"Heat_Grid\",          # The Thermal connection\n","\n","              efficiency=0.70,\n","              efficiency2=0.224,\n","              efficiency3=-0.15,\n","              efficiency4=-0.18,\n","\n","              # THE AUTOTHERMAL TRICK:\n","              # It generates its own heat internally. No external heat required!\n","              efficiency5=0.0,\n","\n","              capital_cost=55000,\n","              p_nom_extendable=True)\n","\n","    else:\n","        raise ValueError(\"Layer must be 1, 2, or 3.\")\n","\n","    return n"],"metadata":{"id":"V1moJflFbU5G","executionInfo":{"status":"ok","timestamp":1774962195526,"user_tz":-120,"elapsed":12,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6cbbbb27","executionInfo":{"status":"ok","timestamp":1774962195569,"user_tz":-120,"elapsed":40,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"2ad4ef81-f7cd-41a0-9405-6fbc1f6bd813"},"source":["import pypsa\n","\n","def build_total_atr(layer=1):\n","    n = pypsa.Network()\n","\n","    # 1. CORE GRIDS (Always Active)\n","    n.add(\"Bus\", \"Methane_Grid\")\n","    n.add(\"Bus\", \"Hydrogen_Grid\")\n","    n.add(\"Bus\", \"CO2_Grid\")\n","\n","    n.add(\"Generator\", \"Gas_Pipeline\", bus=\"Methane_Grid\", marginal_cost=40)\n","\n","    # 2. THE PHYSICS LAYERS (ATR)\n","    if layer == 1:\n","        print(\"Layer 1: Energy Only (Total ATR)\")\n","        n.add(\"Link\", \"ATR_Total_Plant\",\n","              bus0=\"Methane_Grid\",\n","              bus1=\"Hydrogen_Grid\",\n","              bus2=\"CO2_Grid\",\n","              efficiency=0.70,           # Produces H2\n","              efficiency2=0.224,         # Emits CO2\n","              capital_cost=55000,\n","              p_nom_extendable=True)\n","\n","    elif layer == 2:\n","        print(\"Layer 2: Energy + Mass (Total ATR + Oxygen)\")\n","        n.add(\"Bus\", \"Water_Grid\")\n","        n.add(\"Bus\", \"Oxygen_Grid\")\n","        n.add(\"Generator\", \"City_Water\", bus=\"Water_Grid\", marginal_cost=1.5)\n","        n.add(\"Generator\", \"ASU_Plant\", bus=\"Oxygen_Grid\", marginal_cost=25)\n","\n","        n.add(\"Link\", \"ATR_Total_Plant\",\n","              bus0=\"Methane_Grid\",\n","              bus1=\"Hydrogen_Grid\",\n","              bus2=\"CO2_Grid\",\n","              bus3=\"Water_Grid\",\n","              bus4=\"Oxygen_Grid\",\n","              efficiency=0.70,\n","              efficiency2=0.224,\n","              efficiency3=-0.15,         # CONSUMES Water\n","              efficiency4=-0.18,         # CONSUMES Oxygen\n","              capital_cost=55000,\n","              p_nom_extendable=True)\n","\n","    elif layer == 3:\n","        print(\"Layer 3: Energy + Mass + Heat (Total ATR)\")\n","        n.add(\"Bus\", \"Water_Grid\")\n","        n.add(\"Bus\", \"Oxygen_Grid\")\n","        n.add(\"Bus\", \"Heat_Grid\")\n","        n.add(\"Generator\", \"City_Water\", bus=\"Water_Grid\", marginal_cost=1.5)\n","        n.add(\"Generator\", \"ASU_Plant\", bus=\"Oxygen_Grid\", marginal_cost=25)\n","        n.add(\"Generator\", \"Aux_Boiler\", bus=\"Heat_Grid\", marginal_cost=30)\n","\n","        n.add(\"Link\", \"ATR_Total_Plant\",\n","              bus0=\"Methane_Grid\",\n","              bus1=\"Hydrogen_Grid\",\n","              bus2=\"CO2_Grid\",\n","              bus3=\"Water_Grid\",\n","              bus4=\"Oxygen_Grid\",\n","              bus5=\"Heat_Grid\",\n","              efficiency=0.70,\n","              efficiency2=0.224,\n","              efficiency3=-0.15,\n","              efficiency4=-0.18,\n","              efficiency5=0.0,           # Internal heat generation\n","              capital_cost=55000,\n","              p_nom_extendable=True)\n","    else:\n","        raise ValueError(\"Layer must be 1, 2, or 3.\")\n","\n","    return n\n","\n","print('Function build_total_atr successfully defined.')"],"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Function build_total_atr successfully defined.\n"]}]},{"cell_type":"markdown","metadata":{"id":"4c1eb83a"},"source":["## Layer 1 (n_atr1)\n"]},{"cell_type":"code","meta