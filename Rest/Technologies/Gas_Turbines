n /usr/local/lib/python3.12/dist-packages (from pyasn1-modules>=0.2.1->google-auth<3.0.0,>=2.26.1->google-cloud-storage->linopy>=0.6.1->pypsa) (0.6.2)\n"]}]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount('/content/drive', force_remount=True)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0j36E6I_EntG","executionInfo":{"status":"ok","timestamp":1773310909746,"user_tz":-60,"elapsed":3635,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"d5fea122-faaa-4a26-d9fd-3dc7fd0fb3da"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["import os\n","import sys\n","ROOT_DIR = os.getcwd()\n","PROJECT_DIR = os.path.join(ROOT_DIR, \"drive/MyDrive/Colab_Notebooks/PyPSA/\")"],"metadata":{"id":"VLmwOE9AEoXp"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["\n","# Gas Turbines"],"metadata":{"id":"opj0GfEYQKPR"}},{"cell_type":"markdown","source":["In the context of the energy transition, gas turbines are evolving to support a decarbonized grid through two primary configurations:\n","\n","Open Cycle (OCGT) and\n","\n","Combined Cycle (CCGT).\n","\n","*   Open Cycle Gas Turbine (OCGT): In this simplified setup, fuel is combusted to drive a turbine directly. The resulting exhaust gases are then released into the atmosphere. While less efficient, OCGTs offer the rapid start-up times essential for balancing the intermittent nature of renewable energy.\n","\n","*   Combined Cycle Gas Turbine (CCGT): This configuration increases efficiency by adding a heat recovery stage. The hot exhaust gases leaving the gas turbine are directed through a Heat Recovery Steam Generator (HRSG) to produce high-pressure steam. This steam drives a secondary steam turbine, allowing both turbines to contribute mechanical work to the shaft.\n"],"metadata":{"id":"PzmoJ2r7Qc__"}},{"cell_type":"markdown","source":["## Hard-Coded Efficiencies"],"metadata":{"id":"GiFoiuhtIqIk"}},{"cell_type":"code","source":["import pypsa\n","import pandas as pd\n","import logging\n","\n","# Mute PyPSA logging\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","# ==========================================\n","# 1. THE DATA LAYER\n","# ==========================================\n","def get_day_ahead_prices():\n","    \"\"\"24-hour day-ahead electricity price profile in €/MWh.\"\"\"\n","    return [\n","        65,  62,  60,  62,  68,   # 00:00 - 04:00\n","        85, 105, 115, 110, 80,    # 05:00 - 09:00\n","        40,  25,  15,  20,  35,   # 10:00 - 14:00\n","        60,  85, 110, 135, 140,   # 15:00 - 19:00\n","        125, 105, 85,  70         # 20:00 - 23:00\n","    ]\n","\n","# ==========================================\n","# 2. THE MULTI-LAYER OPTIMIZATION MODEL\n","# ==========================================\n","def run_turbine_model(layer, tech_type, market_prices):\n","    \"\"\"\n","    layer: 1 (Black Box) or 2 (White Box Components)\n","    tech_type: \"OCGT\", \"CCGT\", or \"Both\"\n","    \"\"\"\n","    n = pypsa.Network()\n","    n.set_snapshots(pd.date_range(\"2025-01-01 00:00\", periods=len(market_prices), freq=\"h\"))\n","\n","    # --- CORE GRIDS & MARKET ---\n","    n.add(\"Bus\", \"Gas_Grid\")\n","    n.add(\"Bus\", \"Electric_Grid\")\n","\n","    n.add(\"Load\", \"City_Demand\", bus=\"Electric_Grid\", p_set=100)\n","    n.add(\"Generator\", \"Gas_Supply\", bus=\"Gas_Grid\", marginal_cost=30, p_nom_extendable=True)\n","    n.add(\"Generator\", \"Grid_Import\", bus=\"Electric_Grid\", marginal_cost=market_prices, p_nom_extendable=True)\n","\n","    # ==========================================\n","    # ADDING OCGT COMPONENTS\n","    # ==========================================\n","    if tech_type in [\"OCGT\", \"Both\"]:\n","        if layer == 1:\n","            n.add(\"Link\", \"OCGT_Plant\", bus0=\"Gas_Grid\", bus1=\"Electric_Grid\",\n","                  efficiency=0.40, capital_cost=50, p_nom_extendable=True)\n","        elif layer == 2:\n","            n.add(\"Bus\", \"OCGT_Hot_Gas\")\n","            n.add(\"Link\", \"OCGT_Combustor\", bus0=\"Gas_Grid\", bus1=\"OCGT_Hot_Gas\", efficiency=1.0, p_nom_extendable=True)\n","            n.add(\"Link\", \"OCGT_Turbine\", bus0=\"OCGT_Hot_Gas\", bus1=\"Electric_Grid\", efficiency=0.40, capital_cost=50, p_nom_extendable=True)\n","\n","    # ==========================================\n","    # ADDING CCGT COMPONENTS\n","    # ==========================================\n","    if tech_type in [\"CCGT\", \"Both\"]:\n","        if layer == 1:\n","            n.add(\"Link\", \"CCGT_Plant\", bus0=\"Gas_Grid\", bus1=\"Electric_Grid\",\n","                  efficiency=0.60, capital_cost=200, p_nom_extendable=True)\n","        elif layer == 2:\n","            n.add(\"Bus\", \"CCGT_Hot_Gas\")\n","            n.add(\"Bus\", \"CCGT_Exhaust\")\n","            n.add(\"Bus\", \"CCGT_Steam\")\n","\n","            n.add(\"Link\", \"CCGT_Combustor\", bus0=\"Gas_Grid\", bus1=\"CCGT_Hot_Gas\", efficiency=1.0, p_nom_extendable=True)\n","            n.add(\"Link\", \"CCGT_Gas_Turbine\", bus0=\"CCGT_Hot_Gas\", bus1=\"Electric_Grid\", bus2=\"CCGT_Exhaust\",\n","                  efficiency=0.40, efficiency2=0.60, capital_cost=100, p_nom_extendable=True)\n","            n.add(\"Link\", \"CCGT_HRSG\", bus0=\"CCGT_Exhaust\", bus1=\"CCGT_Steam\", efficiency=0.80, p_nom_extendable=True)\n","            n.add(\"Link\", \"CCGT_Steam_Turbine\", bus0=\"CCGT_Steam\", bus1=\"Electric_Grid\",\n","                  efficiency=0.4167, capital_cost=100, p_nom_extendable=True)\n","\n","    # Sanitize the network to define carriers and avoid warnings\n","    n.sanitize()\n","\n","    # ==========================================\n","    # 3. EXECUTION & OUTPUT FORMATTING\n","    # ==========================================\n","    status = n.optimize(solver_name='highs', include_objective_constant=False)\n","\n","    if status[0] == \"ok\":\n","        print(f\"\\n✅ LAYER {layer} | TECH: {tech_type} | OPTIMIZATION SUCCESS\")\n","        print(\"=\"*65)\n","\n","        # Base DataFrame\n","        dispatch = pd.DataFrame({\n","            \"Grid Price (€)\": market_prices,\n","            \"Grid Import (MW)\": n.generators_t.p[\"Grid_Import\"].round(1)\n","        })\n","\n","        # Dynamically append columns based on what was built\n","        print(\"CAPACITY BUILT:\")\n","        if tech_type in [\"OCGT\", \"Both\"]:\n","            if layer == 1:\n","                dispatch[\"OCGT (MW)\"] = n.links_t.p1[\"OCGT_Plant\"].round(1)\n","                print(f\"OCGT Plant:         {n.links.p_nom_opt['OCGT_Plant']:>6.1f} MW\")\n","            elif layer == 2:\n","                dispatch[\"OCGT Turbine (MW)\"] = n.links_t.p1[\"OCGT_Turbine\"].round(1)\n","                print(f\"OCGT Turbine:       {n.links.p_nom_opt['OCGT_Turbine']:>6.1f} MW\")\n","\n","        if tech_type in [\"CCGT\", \"Both\"]:\n","            if layer == 1:\n","                dispatch[\"CCGT (MW)\"] = n.links_t.p1[\"CCGT_Plant\"].round(1)\n","                print(f\"CCGT Plant:         {n.links.p_nom_opt['CCGT_Plant']:>6.1f} MW\")\n","            elif layer == 2:\n","                dispatch[\"CCGT Gas Turb\"] = n.links_t.p1[\"CCGT_Gas_Turbine\"].round(1)\n","                dispatch[\"CCGT Steam Turb\"] = n.links_t.p1[\"CCGT_Steam_Turbine\"].round(1)\n","                dispatch[\"CCGT Total (MW)\"] = dispatch[\"CCGT Gas Turb\"] + dispatch[\"CCGT Steam Turb\"]\n","                print(f\"CCGT Gas Turbine:   {n.links.p_nom_opt['CCGT_Gas_Turbine']:>6.1f} MW\")\n","                print(f\"CCGT Steam Turbine: {n.links.p_nom_opt['CCGT_Steam_Turbine']:>6.1f} MW\")\n","\n","        print(\"-\" * 65)\n","        print(f\"Total Daily System Cost:  €{n.objective:,.2f}\")\n","        print(\"-\" * 65)\n","        # Showing just a snippet of the dataframe to keep the console clean\n","        print(\"HOURLY D