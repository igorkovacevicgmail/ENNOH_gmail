mport pandas as pd\n","import logging\n","\n","logging.getLogger(\"pypsa\").setLevel(logging.WARNING)\n","\n","# ==========================================\n","# 1. THE THERMODYNAMIC BRIDGE (Cantera)\n","# ==========================================\n","def get_turbine_thermo(T_combustor_C=1200):\n","    \"\"\"\n","    Calculates efficiencies for Gas Turbine and Steam Cycle using Cantera.\n","    \"\"\"\n","    gas = ct.Solution('gri30.yaml')\n","\n","    # 1. Inlet Air\n","    gas.TPX = 25 + 273.15, ct.one_atm, 'O2:0.21, N2:0.79'\n","    h_inlet = gas.enthalpy_mass\n","\n","    # 2. Combustion (Stoichiometric CH4)\n","    # We simulate the heat release per kg of fuel\n","    gas.set_equivalence_ratio(1.0, 'CH4', 'O2:0.21, N2:0.79')\n","    gas.equilibrate('HP') # Constant Pressure Combustion\n","    h_post_combustor = gas.enthalpy_mass\n","    T_post_combustor = gas.T\n","\n","    # 3. Gas Turbine Expansion\n","    # Isentropic expansion to 1 atm (simplified)\n","    s1 = gas.s\n","    gas.TP = T_combustor_C + 273.15, 15 * ct.one_atm # 15:1 Pressure Ratio\n","    h_turbine_in = gas.enthalpy_mass\n","\n","    # Entropy constant expansion\n","    gas.SP = s1, ct.one_atm\n","    h_turbine_out = gas.enthalpy_mass\n","\n","    # Work Extracted (Electric Efficiency)\n","    work_turbine = h_turbine_in - h_turbine_out\n","    q_fuel = 50e6 # LHV of Methane J/kg\n","\n","    eff_electrical_gt = work_turbine / q_fuel\n","    eff_exhaust_heat = (h_turbine_out - h_inlet) / q_fuel\n","\n","    return {\n","        \"gt_elec_eff\": round(float(eff_electrical_gt), 4),\n","        \"gt_heat_eff\": round(float(eff_exhaust_heat), 4),\n","        \"hrsg_eff\": 0.85, # Standard heat exchanger effectiveness\n","        \"steam_turb_eff\": 0.40 # Standard Rankine cycle efficiency\n","    }\n","\n","# ==========================================\n","# 2. THE MULTI-LAYER OPTIMIZATION MODEL\n","# ==========================================\n","def run_turbine_model(layer, tech_type, market_prices, thermo):\n","    n = pypsa.Network()\n","    n.set_snapshots(pd.date_range(\"2026-01-01 00:00\", periods=len(market_prices), freq=\"h\"))\n","\n","    n.add(\"Bus\", \"Gas_Grid\")\n","    n.add(\"Bus\", \"Electric_Grid\")\n","    n.add(\"Load\", \"City_Demand\", bus=\"Electric_Grid\", p_set=100)\n","    n.add(\"Generator\", \"Gas_Supply\", bus=\"Gas_Grid\", marginal_cost=35, p_nom_extendable=True)\n","    n.add(\"Generator\", \"Grid_Import\", bus=\"Electric_Grid\", marginal_cost=market_prices, p_nom_extendable=True)\n","\n","    # --- LAYER 1: BLACK BOX ---\n","    if layer == 1:\n","        if tech_type in [\"OCGT\", \"Both\"]:\n","            n.add(\"Link\", \"OCGT_Plant\", bus0=\"Gas_Grid\", bus1=\"Electric_Grid\",\n","                  efficiency=thermo[\"gt_elec_eff\"], capital_cost=50, p_nom_extendable=True)\n","        if tech_type in [\"CCGT\", \"Both\"]:\n","            # Total eff = GT_elec + (GT_heat * HRSG * Steam_Turb)\n","            total_ccgt_eff = thermo[\"gt_elec_eff\"] + (thermo[\"gt_heat_eff\"] * thermo[\"hrsg_eff\"] * thermo[\"steam_turb_eff\"])\n","            n.add(\"Link\", \"CCGT_Plant\", bus0=\"Gas_Grid\", bus1=\"Electric_Grid\",\n","                  efficiency=total_ccgt_eff, capital_cost=200, p_nom_extendable=True)\n","\n","    # --- LAYER 2: WHITE BOX (Physics Driven) ---\n","    elif layer == 2:\n","        if tech_type in [\"OCGT\", \"Both\"]:\n","            n.add(\"Bus\", \"OCGT_Exhaust\")\n","            n.add(\"Link\", \"OCGT_Turbine\", bus0=\"Gas_Grid\", bus1=\"Electric_Grid\", bus2=\"OCGT_Exhaust\",\n","                  efficiency=thermo[\"gt_elec_eff\"], efficiency2=thermo[\"gt_heat_eff\"], capital_cost=50, p_nom_extendable=True)\n","\n","        if tech_type in [\"CCGT\", \"Both\"]:\n","            n.add(\"Bus\", \"CCGT_Exhaust\")\n","            n.add(\"Bus\", \"CCGT_Steam\")\n","            n.add(\"Link\", \"CCGT_Gas_Turbine\", bus0=\"Gas_Grid\", bus1=\"Electric_Grid\", bus2=\"CCGT_Exhaust\",\n","                  efficiency=thermo[\"gt_elec_eff\"], efficiency2=thermo[\"gt_heat_eff\"], capital_cost=100, p_nom_extendable=True)\n","            n.add(\"Link\", \"CCGT_HRSG\", bus0=\"CCGT_Exhaust\", bus1=\"CCGT_Steam\", efficiency=thermo[\"hrsg_eff\"], p_nom_extendable=True)\n","            n.add(\"Link\", \"CCGT_Steam_Turbine\", bus0=\"CCGT_Steam\", bus1=\"Electric_Grid\", efficiency=thermo[\"steam_turb_eff\"], capital_cost=100, p_nom_extendable=True)\n","\n","    n.sanitize()\n","    status = n.optimize(solver_name='highs', include_objective_constant=False)\n","    return n if status[0] == \"ok\" else None\n","\n","# ==========================================\n","# 3. RUNNING THE MODEL\n","# ==========================================\n","german_prices = [65, 62, 60, 62, 68, 85, 105, 115, 110, 80, 40, 25, 15, 20, 35, 60, 85, 110, 135, 140, 125, 105, 85, 70]\n","\n","# Generate physics-based parameters\n","physics = get_turbine_thermo(T_combustor_C=1300)\n","\n","print(f\"Cantera Results: GT Elec Eff: {physics['gt_elec_eff']*100}%, Exhaust Heat: {physics['gt_heat_eff']*100}%\")\n","\n","# Run Layer 2 Component Model\n","optimized_n = run_turbine_model(layer=2, tech_type=\"Both\", market_prices=german_prices, thermo=physics)\n","\n","if optimized_n:\n","    print(f\"Optimization Complete. Total System Cost: €{optimized_n.objective:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0jj0H0Uydh1k","executionInfo":{"status":"ok","timestamp":1773310940153,"user_tz":-60,"elapsed":2786,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"e24decc7-0c72-4c9a-bc9a-104af9d63898"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Cantera Results: GT Elec Eff: -1.9300000000000002%, Exhaust Heat: -0.51%\n","Optimization Complete. Total System Cost: €186,200.00\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"iNSIxgqSrQUA"},"execution_count":null,"outputs":[]},{"cell_type":"code","metadata":{"colab":{"b