linewidth=2, label='City Demand (100 MW)')\n","\n","    ax.set_title('Hourly Dispatch for Competing OCGT and CCGT (Layer 2)')\n","    ax.set_xlabel('Hour of Day')\n","    ax.set_ylabel('Power (MW)')\n","    ax.legend(title='Source')\n","    ax.grid(axis='y', linestyle='--', alpha=0.7)\n","    plt.xticks(rotation=45, ha='right')\n","    plt.tight_layout()\n","    plt.show()\n","else:\n","    print(\"df_compete DataFrame not found. Please ensure the model runs have been executed.\")\n"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["print(\"City Demand Profile (MW):\")\n","print(demand)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"KMj8B1-yrhK2","executionInfo":{"status":"ok","timestamp":1773312841352,"user_tz":-60,"elapsed":4,"user":{"displayName":"Igor Kovacevic","userId":"01095176641533826550"}},"outputId":"1b3b3aca-7d7e-4a4b-c01f-1612294a0af3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["City Demand Profile (MW):\n","snapshot\n","2025-01-01 00:00:00    100\n","2025-01-01 01:00:00    100\n","2025-01-01 02:00:00    100\n","2025-01-01 03:00:00    100\n","2025-01-01 04:00:00    100\n","2025-01-01 05:00:00    100\n","2025-01-01 06:00:00    100\n","2025-01-01 07:00:00    100\n","2025-01-01 08:00:00    100\n","2025-01-01 09:00:00    100\n","2025-01-01 10:00:00    100\n","2025-01-01 11:00:00    100\n","2025-01-01 12:00:00    100\n","2025-01-01 13:00:00    100\n","2025-01-01 14:00:00    100\n","2025-01-01 15:00:00    100\n","2025-01-01 16:00:00    100\n","2025-01-01 17:00:00    100\n","2025-01-01 18:00:00    100\n","2025-01-01 19:00:00    100\n","2025-01-01 20:00:00    100\n","2025-01-01 21:00:00    100\n","2025-01-01 22:00:00    100\n","2025-01-01 23:00:00    100\n","Freq: h, dtype: int64\n"]}]}]}