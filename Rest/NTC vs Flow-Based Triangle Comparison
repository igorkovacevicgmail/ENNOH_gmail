\"A\", p_nom=1500, marginal_cost=20)\n","    n.add(\"Generator\", \"Gas_B\",  bus=\"B\", p_nom=1500, marginal_cost=80)\n","    n.add(\"Load\", \"Demand_C\", bus=\"C\", p_set=1000)\n","\n","    # 3. Add Physical Grid (Lines with Reactance 'x')\n","    # All lines have equal impedance (x=1.0) and a physical Thermal Limit of 600 MW.\n","    n.add(\"Line\", \"Line_A_C\", bus0=\"A\", bus1=\"C\", s_nom=600, x=1.0, r=0.1)\n","    n.add(\"Line\", \"Line_A_B\", bus0=\"A\", bus1=\"B\", s_nom=600, x=1.0, r=0.1)\n","    n.add(\"Line\", \"Line_B_C\", bus0=\"B\", bus1=\"C\", s_nom=600, x=1.0, r=0.1)\n","\n","    n.sanitize()\n","    # Solve (PyPSA automatically uses linear optimal power flow for Lines)\n","    n.optimize(solver_name='highs')\n","    return n\n","\n","def print_results(model, model_name, is_fb=False):\n","    print(f\"\\n{'='*40}\")\n","    print(f\" RESULTS: {model_name.upper()} MODEL \")\n","    print(f\"{'='*40}\")\n","\n","    print(\"\\n--- GENERATION (MW) ---\")\n","    if not model.generators_t.p.empty:\n","        print(model.generators_t.p.round(2).to_string(index=False))\n","    else:\n","        print(\"No generation data available (model might be infeasible).\")\n","\n","    print(\"\\n--- PRICES (в‚¬/MWh) ---\")\n","    if not model.buses_t.marginal_price.empty:\n","        print(model.buses_t.marginal_price.round(2).to_string(index=False))\n","    else:\n","        print(\"No price data available (model might be infeasible).\")\n","\n","    print(\"\\n--- LINE FLOWS (MW) ---\")\n","    if is_fb:\n","        if not model.lines_t.p0.empty:\n","            print(model.lines_t.p0.round(2).to_string(index=False))\n","        else:\n","            print(\"No line flow data available (model might be infeasible).\")\n","    else:\n","        if not model.links_t.p0.empty:\n","            print(model.links_t.p0.round(2).to_string(index=False))\n","        else:\n","            print(\"No link flow data available (model might be infeasible).\")\n","\n","    if